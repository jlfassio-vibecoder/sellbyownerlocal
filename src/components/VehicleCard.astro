---
import type { VehicleResponse } from '../schemas';
import { resolveHeroImageUrls } from '../lib/resolve-display-media';
import { getAccent } from '../lib/accent-colors';
import { getVehicleListingPath } from '../utils/url-helpers';

interface Props {
  vehicle: VehicleResponse;
}

const { vehicle } = Astro.props;
const accent = getAccent(vehicle.accentColor);
const heroImage = resolveHeroImageUrls(vehicle)[0];

const priceFormatter = new Intl.NumberFormat('en-US', {
  style: 'currency',
  currency: 'USD',
  maximumFractionDigits: 0,
});

const mileageFormatter = new Intl.NumberFormat('en-US');
---

<a
  href={getVehicleListingPath(vehicle)}
  class="block overflow-hidden rounded-xl border border-gray-200 bg-white shadow-sm transition-shadow hover:shadow-lg"
>
  {
    heroImage ? (
      <img
        src={heroImage}
        alt={`${vehicle.year} ${vehicle.make} ${vehicle.model}`}
        class="aspect-[4/3] w-full object-cover"
      />
    ) : (
      <div class="flex aspect-[4/3] w-full items-center justify-center bg-gray-200 text-sm text-gray-500">
        No photo
      </div>
    )
  }
  <div class="space-y-2 p-4">
    <h2 class="text-lg font-semibold text-gray-900">
      {vehicle.year} {vehicle.make}{' '}
      <span class={accent.tailwindText}>{vehicle.model}</span>
    </h2>
    <p class="text-lg font-semibold text-gray-900">{priceFormatter.format(vehicle.price)}</p>
    <p class="text-sm text-gray-500">
      {mileageFormatter.format(vehicle.mileage)} mi · {vehicle.location.city}
    </p>
    <p class="text-sm text-gray-400">Listed by {vehicle.sellerName}</p>
  </div>
</a>
