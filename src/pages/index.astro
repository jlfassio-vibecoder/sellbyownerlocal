---
import Layout from '../layouts/Layout.astro';
import { getOptionalSellerSession } from '../lib/auth';
import { getPublishedInventory } from '../lib/inventory-api';
import AuthForm from '../islands/AuthForm';
import InventoryGrid from '../islands/buyer/InventoryGrid';
import ContactSellerFab from '../islands/buyer/ContactSellerFab';

const session = await getOptionalSellerSession(Astro.request, Astro.cookies);
const displayName = session?.email?.split('@')[0] ?? 'there';
const vehicles = await getPublishedInventory();
const buyerContext = {
  isLoggedIn: !!session,
  verificationTier: session?.verificationTier ?? 'anonymous',
};
---

<Layout>
  <header class="border-b border-slate-200 bg-white">
    <div class="mx-auto max-w-7xl px-4 py-8 sm:px-6 sm:py-10 lg:px-8 lg:py-12">
      <div class="flex items-center gap-5 sm:gap-6">
        <a href="/" class="shrink-0" aria-label="Sell By Owner Local home">
          <img
            src="/images/logo.png"
            alt="Sell By Owner Local"
            class="h-[5.4rem] w-auto sm:h-[6.75rem] lg:h-[8.1rem]"
          />
        </a>
        <div>
          <h1 class="font-brand text-4xl leading-none text-slate-900 uppercase sm:text-5xl lg:text-6xl">
            Sell By Owner Local
          </h1>
          <p class="mt-2 text-base text-slate-500 sm:mt-3 sm:text-lg">
            Vehicles listed directly by their owners
          </p>
        </div>
      </div>
    </div>
  </header>

  <section class="hero-wave-bg relative overflow-hidden border-b border-sky-200/70">
    <div
      class="relative z-10 grid grid-cols-1 lg:grid-cols-2 gap-12 items-center max-w-7xl mx-auto px-4 sm:px-6 lg:px-8 py-16"
    >
      <div>
        <h1 class="text-5xl md:text-6xl lg:text-7xl font-extrabold tracking-tight leading-tight text-slate-900">
          The Private Market,
          <br />
          <span class="font-semibold opacity-80">Professionalized.</span>
        </h1>
        <div class="mt-6 space-y-4 text-lg md:text-xl text-slate-600 max-w-xl">
          <p>
            <span class="font-bold">For Sellers:</span> Turn your car into a professional retail
            listing in less than a minute with just your VIN #.
          </p>
          <p>
            <span class="font-bold">For Buyers:</span> Browse owner-listed cars with zero dealer
            markup and 100% ID-verified transparency.
          </p>
        </div>
        <ul
          class="mt-8 flex flex-wrap gap-x-6 gap-y-2 text-sm md:text-base font-medium italic text-slate-500 list-none"
        >
          <li class="flex items-center gap-2 before:content-['•']">Direct from Owners</li>
          <li class="flex items-center gap-2 before:content-['•']">No Dealer Markup</li>
          <li class="flex items-center gap-2 before:content-['•']">Verified Identity Secure</li>
        </ul>
      </div>

      {
        session ? (
          <div class="bg-white rounded-2xl shadow-xl border border-slate-100 p-6 sm:p-8 max-w-md mx-auto w-full text-center">
            <p class="text-lg font-semibold text-slate-900">Welcome back, {displayName}</p>
            <p class="mt-2 text-sm text-slate-500">Ready to manage your listings?</p>
            <a
              href="/seller"
              class="mt-6 inline-block w-full rounded-lg bg-red-600 px-4 py-2.5 text-sm font-semibold text-white transition-colors hover:bg-red-700"
            >
              Go to Seller Dashboard
            </a>
            {
              session.isDealer && (
                <a
                  href="/dealer/new"
                  class="mt-3 inline-block w-full rounded-lg border border-slate-200 px-4 py-2.5 text-sm font-semibold text-slate-700 transition-colors hover:bg-slate-50"
                >
                  New AI Listing
                </a>
              )
            }
            <a href="/account" class="mt-3 block text-sm font-semibold text-red-600 hover:text-red-700">
              Account settings
            </a>
          </div>
        ) : (
          <div id="hero-auth" class="max-w-md mx-auto w-full">
            <div class="bg-white rounded-2xl shadow-xl border border-slate-100 p-6 sm:p-8">
              <AuthForm client:load embedded />
            </div>
            <p class="mt-4 text-center text-sm leading-relaxed text-slate-500 px-2">
              Create an account to become a verified buyer or seller—or browse listings and send
              inquiries anonymously without signing up.
            </p>
          </div>
        )
      }
    </div>
  </section>

  <section id="inventory">
    {
      vehicles.length > 0 ? (
        <InventoryGrid client:load initialVehicles={vehicles} buyerContext={buyerContext} />
      ) : (
        <main class="mx-auto max-w-7xl px-4 py-8 sm:px-6 lg:px-8">
          <div class="rounded-xl border border-dashed border-slate-300 bg-white p-12 text-center">
            <p class="text-lg font-medium text-slate-700">No vehicles listed yet</p>
            <p class="mt-2 text-sm text-slate-500">
              In development, seed sample data by visiting{' '}
              <a href="/api/dev/seed" class="rounded bg-slate-100 px-1.5 py-0.5 text-xs underline">
                /api/dev/seed
              </a>
            </p>
          </div>
        </main>
      )
    }
  </section>

  <section class="border-t border-slate-200 bg-white py-16">
    <div class="mx-auto max-w-7xl px-4 sm:px-6 lg:px-8">
      <h2 class="text-3xl font-bold text-slate-900">Explore Local Categories</h2>
      <p class="mt-2 text-slate-500">Frictionless, local deals beyond automotive.</p>

      <div class="mx-auto mt-8 grid max-w-7xl grid-cols-1 gap-6 px-4 sm:grid-cols-2 md:grid-cols-3">
        <a
          href="#inventory"
          class="group block overflow-hidden rounded-xl border border-slate-200 bg-white shadow-sm transition-shadow hover:shadow-lg"
        >
          <div class="flex h-32 items-center justify-center bg-gradient-to-br from-slate-100 to-sky-100">
            <svg
              xmlns="http://www.w3.org/2000/svg"
              class="h-12 w-12 text-slate-600 transition-colors group-hover:text-sky-600"
              fill="none"
              viewBox="0 0 24 24"
              stroke="currentColor"
              stroke-width="1.5"
              aria-hidden="true"
            >
              <path
                stroke-linecap="round"
                stroke-linejoin="round"
                d="M8.25 18.75a1.5 1.5 0 0 1-3 0m3 0a1.5 1.5 0 0 0-3 0m3 0h6m-9 0H3.375a1.125 1.125 0 0 1-1.125-1.125V14.25m17.25 4.5a1.5 1.5 0 0 1-3 0m3 0a1.5 1.5 0 0 0-3 0m3 0h1.125c.621 0 1.129-.504 1.09-1.124a17.902 17.902 0 0 0-3.213-9.193 2.056 2.056 0 0 0-1.58-.86H14.25M16.5 18.75h-2.25m0-11.177v-.958c0-.568-.422-1.048-.987-1.106a48.554 48.554 0 0 0-10.026 0 1.106 1.106 0 0 0-.987 1.106v7.635m12-6.677v6.677m0 4.5v-4.5m0 0h-12"
              ></path>
            </svg>
          </div>
          <div class="space-y-1 p-4">
            <h3 class="text-lg font-bold text-slate-900">Vehicles & Trucks</h3>
            <p class="text-sm text-slate-500">Browse owner-listed cars with zero dealer markup.</p>
          </div>
        </a>

        <a
          href="/marketplace/clothing"
          class="group block overflow-hidden rounded-xl border border-slate-200 bg-white shadow-sm transition-shadow hover:shadow-lg"
        >
          <div class="flex h-32 items-center justify-center bg-gradient-to-br from-rose-50 to-slate-100">
            <svg
              xmlns="http://www.w3.org/2000/svg"
              class="h-12 w-12 text-slate-600 transition-colors group-hover:text-rose-600"
              fill="none"
              viewBox="0 0 24 24"
              stroke="currentColor"
              stroke-width="1.5"
              aria-hidden="true"
            >
              <path
                stroke-linecap="round"
                stroke-linejoin="round"
                d="M15.75 10.5V6a3.75 3.75 0 1 0-7.5 0v4.5m11.356-1.993 1.263 12c.07.665-.45 1.243-1.119 1.243H4.25a1.125 1.125 0 0 1-1.12-1.243l1.264-12A1.125 1.125 0 0 1 5.513 7.5h12.974c.576 0 1.059.435 1.119 1.007ZM8.625 10.5a.375.375 0 1 1-.75 0 .375.375 0 0 1 .75 0Zm7.5 0a.375.375 0 1 1-.75 0 .375.375 0 0 1 .75 0Z"
              ></path>
            </svg>
          </div>
          <div class="space-y-1 p-4">
            <h3 class="text-lg font-bold text-slate-900">Clothing & Apparel</h3>
            <p class="text-sm text-slate-500">Local fashion and apparel from independent reps.</p>
            <span class="inline-block pt-1 text-sm font-semibold text-red-600 group-hover:text-red-700">
              Browse →
            </span>
          </div>
        </a>
      </div>
    </div>
  </section>

  {
    vehicles.length === 0 && (
      <ContactSellerFab
        client:load
        isLoggedIn={buyerContext.isLoggedIn}
        verificationTier={buyerContext.verificationTier}
      />
    )
  }
</Layout>
