---
interface Props {
  uid: string;
}

const { uid } = Astro.props;
---

<section
  class="mb-8 rounded-xl border border-red-100 bg-red-50 px-5 py-4 shadow-sm"
  aria-label="Account identifier"
>
  <p class="text-[10px] font-bold uppercase tracking-wider text-red-600">Your UID</p>
  <p class="mt-1 font-mono text-lg font-semibold text-slate-900 break-all select-all">
    {uid}
  </p>
  <p class="mt-2 text-xs text-slate-500">
    Link this ID to your vehicle listings in Firestore as <code class="text-slate-700">sellerId</code>.
  </p>
</section>
