---
import { requireSellerOrRedirect } from '../../../lib/auth';
import { getUserProfile } from '../../../lib/buyer-profile';
import { getApparelCatalogForSeller } from '../../../lib/clothing-api';
import ApparelSellerLayout from '../../../islands/seller/ApparelSellerLayout';
import ApparelCatalogSection from '../../../islands/seller/ApparelCatalogSection';
import ShareCatalogButton from '../../../islands/seller/ShareCatalogButton';
import type { ApparelFilterItem } from '../../../lib/apparel';
import { resolveStorefrontSegment, getStorefrontPath } from '../../../utils/url-helpers';
import '../../../styles/global.css';

const seller = await requireSellerOrRedirect(Astro.request, Astro.cookies);
if (seller instanceof Response) return seller;

const profile = await getUserProfile(seller.uid);
const storefrontSegment = resolveStorefrontSegment({
  id: seller.uid,
  storefrontSlug: profile?.storefrontSlug,
});
const storefrontHref = getStorefrontPath(storefrontSegment);
const storefrontUrl = new URL(storefrontHref, Astro.site?.href ?? Astro.url.origin).href;
const catalog = await getApparelCatalogForSeller(seller.uid);

const initialItems: ApparelFilterItem[] = catalog.map((item) => ({
  id: item.id,
  title: item.title,
  brand: item.brand,
  price: item.price,
  description: item.description,
  status: item.status,
  galleryPhotos: item.galleryPhotos,
  material: item.material,
  sizes: item.sizes,
  colors: item.colors,
  isFeatured: item.isFeatured,
  isSale: item.isSale,
  salePrice: item.salePrice,
  sortOrder: item.sortOrder,
  featuredSortOrder: item.featuredSortOrder,
  createdAt: item.createdAt,
}));
---

<html lang="en">
  <head>
    <meta charset="utf-8" />
    <link rel="icon" href="/favicon.ico" sizes="any" />
    <link rel="icon" type="image/png" href="/favicon.png" />
    <link rel="apple-touch-icon" href="/apple-touch-icon.png" />
    <meta name="viewport" content="width=device-width" />
    <meta name="generator" content={Astro.generator} />
    <title>My Catalog · Apparel Dashboard · Sell By Owner Local</title>
  </head>
  <body class="min-h-screen bg-[#f8f9fa] font-sans text-slate-900">
    <ApparelSellerLayout
      client:load
      activeNav="catalog"
      storefrontHref={storefrontHref}
    >
      <div class="flex-1 overflow-y-auto">
        <div class="mx-auto max-w-6xl px-4 py-8 sm:px-6">
          <div class="mb-8 flex flex-wrap items-end justify-between gap-4">
            <div>
              <h2 class="text-2xl font-bold text-slate-900">My Catalog</h2>
              <p class="mt-1 text-sm text-slate-500">Select an item to manage</p>
            </div>
            <div class="flex flex-wrap items-center gap-3">
              <ShareCatalogButton client:load storefrontUrl={storefrontUrl} />
              <a
                href="/seller/apparel/new"
                class="inline-flex items-center rounded-lg bg-red-600 px-4 py-2.5 text-sm font-semibold text-white shadow-sm transition-colors hover:bg-red-700"
              >
                Add Catalog Item
              </a>
            </div>
          </div>

          <ApparelCatalogSection
            client:load
            sellerId={seller.uid}
            initialItems={initialItems}
            storefrontSegment={storefrontSegment}
          />
        </div>
      </div>
    </ApparelSellerLayout>
  </body>
</html>
