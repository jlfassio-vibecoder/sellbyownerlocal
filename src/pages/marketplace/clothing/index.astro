---
import Layout from '../../../layouts/Layout.astro';
import { getOptionalSellerSession } from '../../../lib/auth';
import { resolveStorefrontSegmentsForSellerIds } from '../../../lib/buyer-profile';
import { getClothingInventory } from '../../../lib/clothing-api';
import ClothingInventoryGrid from '../../../islands/buyer/ClothingInventoryGrid';
import ContactSellerFab from '../../../islands/buyer/ContactSellerFab';

const session = await getOptionalSellerSession(Astro.request, Astro.cookies);
const listings = await getClothingInventory();
const storefrontSegmentsBySellerId = await resolveStorefrontSegmentsForSellerIds(
  listings.map((listing) => listing.sellerId)
);
const buyerContext = {
  isLoggedIn: !!session,
  verificationTier: session?.verificationTier ?? 'anonymous',
};
---

<Layout
  title="Clothing & Apparel · Sell By Owner Local"
  description="Browse local clothing and apparel from independent reps. Frictionless, local deals beyond automotive."
>
  <header class="border-b border-slate-200 bg-white">
    <div class="mx-auto max-w-7xl px-4 py-8 sm:px-6 sm:py-10 lg:px-8 lg:py-12">
      <div class="flex items-center gap-5 sm:gap-6">
        <a href="/" class="shrink-0" aria-label="Sell By Owner Local home">
          <img
            src="/images/logo.png"
            alt="Sell By Owner Local"
            class="h-[4.5rem] w-auto sm:h-[5.4rem]"
          />
        </a>
        <div>
          <h1 class="font-brand text-4xl leading-none text-slate-900 uppercase sm:text-5xl">
            Clothing & Apparel
          </h1>
          <p class="mt-2 text-base text-slate-500 sm:text-lg">
            Local fashion from independent reps
          </p>
        </div>
      </div>
    </div>
  </header>

  {
    listings.length > 0 ? (
      <ClothingInventoryGrid
        client:load
        initialListings={listings}
        storefrontSegmentsBySellerId={storefrontSegmentsBySellerId}
        buyerContext={buyerContext}
      />
    ) : (
      <main class="mx-auto max-w-7xl px-4 py-8 sm:px-6 lg:px-8">
        <div class="rounded-xl border border-dashed border-slate-300 bg-white p-12 text-center">
          <p class="text-lg font-medium text-slate-700">No clothing listed yet</p>
          <p class="mt-2 text-sm text-slate-500">
            Check back soon for local apparel from independent reps.
          </p>
        </div>
      </main>
    )
  }

  {
    listings.length === 0 && (
      <ContactSellerFab
        client:load
        isLoggedIn={buyerContext.isLoggedIn}
        verificationTier={buyerContext.verificationTier}
      />
    )
  }
</Layout>
