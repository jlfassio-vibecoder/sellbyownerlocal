---
import Layout from '../../../../layouts/Layout.astro';
import { getOptionalSession } from '../../../../lib/auth';
import {
  resolveSellerByStorefrontParam,
} from '../../../../lib/buyer-profile';
import { getClothingListingById } from '../../../../lib/clothing-api';
import {
  buildClothingSeoDescription,
  buildClothingSeoTitle,
  resolveAbsoluteUrl,
  resolveClothingOgImage,
} from '../../../../lib/seo';
import {
  getClothingListingPath,
  getStorefrontPath,
  resolveStorefrontSegment,
} from '../../../../utils/url-helpers';
import ApparelImageGallery from '../../../../islands/ApparelImageGallery';
import ApparelListingImage from '../../../../components/apparel/ApparelListingImage';
import ContactForm from '../../../../islands/ContactForm';
import DocumentViewer from '../../../../islands/DocumentViewer';
import FavoriteButton from '../../../../islands/buyer/FavoriteButton';
import ContactSellerFab from '../../../../islands/buyer/ContactSellerFab';
import { db } from '../../../../lib/firebase-admin';

const { storefrontSlug: param, id } = Astro.params;

if (!param || !id) {
  return Astro.rewrite('/404');
}

const resolvedSeller = await resolveSellerByStorefrontParam(param);
if (!resolvedSeller) {
  return Astro.rewrite('/404');
}

const listing = await getClothingListingById(id);
if (!listing) {
  return Astro.rewrite('/404');
}

// Strict ownership: do not serve a listing under another seller's storefront.
if (listing.sellerId !== resolvedSeller.id) {
  return Astro.rewrite('/404');
}

const canonicalSegment = resolveStorefrontSegment(resolvedSeller);
const canonicalPath = getClothingListingPath(listing.id, canonicalSegment);

// Previous slug / UID fallback → 301 to current canonical nested URL.
if (param !== canonicalSegment) {
  return Astro.redirect(canonicalPath, 301);
}

const wholesalePriceFormatter = new Intl.NumberFormat('en-US', {
  style: 'currency',
  currency: 'USD',
  minimumFractionDigits: 2,
});

const hasSalePricing =
  Boolean(listing.isSale) &&
  typeof listing.salePrice === 'number' &&
  listing.salePrice < listing.price;

const origin = Astro.site?.href ?? Astro.url.origin;
const seoTitle = buildClothingSeoTitle(listing);
const seoDescription = buildClothingSeoDescription(listing);
const seoImage = resolveClothingOgImage(listing);
const canonicalUrl = resolveAbsoluteUrl(canonicalPath, origin);
const galleryImages = listing.galleryPhotos?.length ? listing.galleryPhotos : [];
const heroImage = listing.galleryPhotos?.[0];
const hasGalleryImages = galleryImages.length > 0;
const session = await getOptionalSession(Astro.request, Astro.cookies);
const isStorefrontOwner = Boolean(session?.uid && session.uid === resolvedSeller.id);
const storefrontPath = getStorefrontPath(canonicalSegment);

let initialSaved = false;
if (session) {
  const saveDoc = await db()
    .collection('saved_clothing')
    .doc(`${session.uid}_${listing.id}`)
    .get();
  initialSaved = saveDoc.exists;
}

const buyerContext = {
  isLoggedIn: !!session,
  verificationTier: session?.verificationTier ?? 'anonymous',
  loginHref: `/login?next=${encodeURIComponent(`${canonicalPath}#contact`)}`,
};

const storefrontTitle =
  resolvedSeller.storefrontName?.trim() || resolvedSeller.displayName;
---

<Layout
  title={`${seoTitle} · Sell By Owner Local`}
  description={seoDescription}
  ogImage={seoImage}
  ogUrl={canonicalUrl}
  ogType="product"
  bodyClass="min-h-screen bg-[#f8f9fa] font-sans text-slate-900"
>
  {
    isStorefrontOwner && (
      <div class="sticky top-0 z-50 border-b border-slate-800 bg-slate-900 text-white shadow-md">
        <div class="mx-auto flex max-w-7xl items-center justify-between gap-3 px-4 py-2.5 sm:px-6 lg:px-8">
          <p class="text-sm text-slate-300">Previewing your storefront</p>
          <a
            href="/seller/apparel"
            class="inline-flex shrink-0 items-center rounded-md border border-white/30 px-3 py-1.5 text-sm font-semibold text-white transition-colors hover:bg-white/10"
          >
            Return to Dashboard
          </a>
        </div>
      </div>
    )
  }

  <header class="border-b border-slate-200 bg-white">
    <div class="mx-auto max-w-6xl px-4 py-6 sm:px-6">
      <a
        href={storefrontPath}
        class="mb-4 inline-flex items-center text-sm font-semibold text-red-600 hover:text-red-700"
      >
        ← Back to {storefrontTitle}
      </a>
    </div>
  </header>

  <main class="relative mx-auto max-w-6xl px-4 py-8 sm:px-6 lg:px-8">
    <section class="mb-16 pt-8">
      <div class="grid grid-cols-1 items-start gap-12 lg:grid-cols-2">
        <div>
          {
            hasGalleryImages ? (
              <ApparelImageGallery
                client:load
                images={galleryImages}
                altText={listing.title}
              />
            ) : (
              <ApparelListingImage
                title={listing.title}
                imageUrl={heroImage}
                className="mb-8 overflow-hidden rounded-xl border border-slate-200 bg-white shadow-sm"
              />
            )
          }

          <div class="rounded-xl border border-slate-200 bg-white p-6 shadow-sm">
            <h2 class="mb-4 text-xl font-bold text-slate-900">Wholesale Details</h2>
            <dl class="space-y-4 text-sm">
              <div>
                <dt class="mb-1 font-semibold text-slate-500 uppercase">Sizes</dt>
                <dd>
                  <ul class="flex flex-wrap gap-1.5">
                    {
                      listing.sizes.map((size) => (
                        <li class="rounded-full bg-slate-100 px-2.5 py-0.5 text-xs text-slate-600">
                          {size}
                        </li>
                      ))
                    }
                  </ul>
                </dd>
              </div>
              {
                listing.colors && listing.colors.length > 0 && (
                  <div>
                    <dt class="mb-1 font-semibold text-slate-500 uppercase">Colors</dt>
                    <dd>
                      <ul class="flex flex-wrap gap-1.5">
                        {listing.colors.map((color) => (
                          <li class="rounded-full bg-slate-100 px-2.5 py-0.5 text-xs text-slate-600">
                            {color}
                          </li>
                        ))}
                      </ul>
                    </dd>
                  </div>
                )
              }
              <div>
                <dt class="mb-1 font-semibold text-slate-500 uppercase">Material</dt>
                <dd class="text-slate-900">{listing.material}</dd>
              </div>
              {
                listing.prePackRatio && (
                  <div>
                    <dt class="mb-1 font-semibold text-slate-500 uppercase">Pre-pack Ratio</dt>
                    <dd class="text-slate-900">{listing.prePackRatio}</dd>
                  </div>
                )
              }
            </dl>
          </div>
        </div>

        <div class="flex flex-col gap-6">
          <div class="flex items-start justify-between gap-4">
            <div class="space-y-2">
              <p class="text-xs font-semibold uppercase tracking-wide text-slate-500">{listing.brand}</p>
              {
                // Copilot suggestion ignored: Sale badge uses isSale so bulk “Mark as Sale” remains visible before a salePrice is set; dual pricing still uses hasSalePricing.
                (listing.isFeatured || listing.isSale) && (
                  <div class="flex flex-wrap gap-1.5">
                    {
                      listing.isFeatured && (
                        <span class="rounded-full bg-red-600 px-2.5 py-0.5 text-xs font-semibold text-white">
                          Featured
                        </span>
                      )
                    }
                    {
                      listing.isSale && (
                        <span class="rounded-full bg-amber-500 px-2.5 py-0.5 text-xs font-semibold text-white">
                          Sale
                        </span>
                      )
                    }
                  </div>
                )
              }
            </div>
            <FavoriteButton
              client:load
              itemId={listing.id}
              title={listing.title}
              price={hasSalePricing ? listing.salePrice! : listing.price}
              category="clothing"
              sellerId={listing.sellerId}
              isLoggedIn={buyerContext.isLoggedIn}
              verificationTier={buyerContext.verificationTier}
              initialSaved={initialSaved}
            />
          </div>
          <h1 class="text-4xl leading-tight font-bold text-slate-900 md:text-5xl">
            {listing.title}
          </h1>

          <div class="inline-block w-max rounded-2xl border border-slate-800 bg-slate-900 p-5 shadow-lg">
            <p class="mb-1 text-sm font-semibold tracking-wider text-slate-400 uppercase">
              {hasSalePricing ? 'Sale Price' : 'Wholesale Price'}
            </p>
            {
              hasSalePricing ? (
                <div class="flex flex-wrap items-baseline gap-3">
                  <p class="text-2xl font-semibold text-red-400 line-through md:text-3xl">
                    {wholesalePriceFormatter.format(listing.price)}
                  </p>
                  <p class="text-4xl font-bold text-emerald-400 md:text-5xl">
                    {wholesalePriceFormatter.format(listing.salePrice!)}
                  </p>
                </div>
              ) : (
                <p class="text-4xl font-bold text-white md:text-5xl">
                  {wholesalePriceFormatter.format(listing.price)}
                </p>
              )
            }
          </div>

          <p class="text-lg leading-relaxed text-slate-600">{listing.description}</p>

          <a
            href="#contact"
            class="inline-flex w-max items-center justify-center rounded-lg bg-red-600 px-6 py-3 text-sm font-bold text-white shadow-sm transition-colors hover:bg-red-700"
          >
            Contact Seller
          </a>
        </div>
      </div>
    </section>

    {
      listing.pdfLineSheetUrl?.trim() && (
        <section class="mb-16 w-full">
          <DocumentViewer
            client:load
            title="Brand Catalog"
            proxyUrl={`/api/clothing/${listing.id}/catalog`}
            originalUrl={listing.pdfLineSheetUrl}
            openButtonLabel="Open Full Catalog"
            defaultPage={listing.pdfDefaultPage ?? undefined}
          />
        </section>
      )
    }

    <ContactForm
      client:load
      vehicleId={listing.id}
      listingIdKey="clothingListingId"
      apiEndpoint="/api/clothing-inquiries"
      sellerId={listing.sellerId}
      isLoggedIn={buyerContext.isLoggedIn}
      verificationTier={buyerContext.verificationTier}
      loginHref={buyerContext.loginHref}
    />
  </main>

  {
    !isStorefrontOwner && (
      <ContactSellerFab
        client:load
        isLoggedIn={buyerContext.isLoggedIn}
        verificationTier={buyerContext.verificationTier}
        initialSavedIds={initialSaved ? [listing.id] : []}
      />
    )
  }
</Layout>
