---
import { db } from '../../../lib/firebase-admin';
import {
  assertVehicleOwner,
  ForbiddenError,
  forbiddenResponse,
  requireSellerOrRedirect,
} from '../../../lib/auth';
import { mapInquiryDoc } from '../../../lib/inquiries';
import { vehicleToFormState } from '../../../lib/vehicle-form-mapper';
import { VehicleResponseSchema } from '../../../schemas';
import SellerVehicleShell from '../../../islands/seller/SellerVehicleShell';
import '../../../styles/global.css';

const { vehicleId } = Astro.params;

if (!vehicleId) {
  return new Response('Vehicle not found', { status: 404, statusText: 'Not Found' });
}

const seller = await requireSellerOrRedirect(Astro.request, Astro.cookies);
if (seller instanceof Response) return seller;

const doc = await db().collection('vehicles').doc(vehicleId).get();

if (!doc.exists) {
  return new Response('Vehicle not found', { status: 404, statusText: 'Not Found' });
}

const raw = { id: doc.id, ...doc.data() };
const parsed = VehicleResponseSchema.safeParse(raw);

if (!parsed.success) {
  return new Response('Vehicle not found', { status: 404, statusText: 'Not Found' });
}

try {
  assertVehicleOwner(seller.uid, parsed.data.sellerId);
} catch (error) {
  if (error instanceof ForbiddenError) {
    return forbiddenResponse();
  }
  throw error;
}

const vehicle = parsed.data;
const vehicleTitle = `${vehicle.year} ${vehicle.make} ${vehicle.model}`;
const initialFormState = vehicleToFormState(vehicle);

const inquirySnapshot = await db()
  .collection('inquiries')
  .where('sellerId', '==', seller.uid)
  .where('vehicleId', '==', vehicleId)
  .orderBy('timestamp', 'desc')
  .get();

const initialInquiries = inquirySnapshot.docs.flatMap((doc) => {
  const parsedInquiry = mapInquiryDoc(doc.id, doc.data() as Record<string, unknown>);
  return parsedInquiry.success ? [parsedInquiry.data] : [];
});
---

<html lang="en">
  <head>
    <meta charset="utf-8" />
    <link rel="icon" type="image/svg+xml" href="/favicon.svg" />
    <link rel="icon" href="/favicon.ico" />
    <meta name="viewport" content="width=device-width" />
    <meta name="generator" content={Astro.generator} />
    <title>{vehicleTitle} · Seller Dashboard</title>
  </head>
  <body>
    <SellerVehicleShell
      client:load
      vehicleId={vehicleId}
      vehicleTitle={vehicleTitle}
      initialInquiries={initialInquiries}
      initialFormState={initialFormState}
    />
  </body>
</html>
