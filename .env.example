# Firebase Admin (server)
FIREBASE_PROJECT_ID=
FIREBASE_CLIENT_EMAIL=
FIREBASE_PRIVATE_KEY=
FIRESTORE_DATABASE_ID=
# Option A: inline service account JSON (single line) — alternative to discrete vars above
# FIREBASE_SERVICE_ACCOUNT_JSON=
# Local dev only: path to service account JSON (not used by src/lib/firebase-admin.ts)
# GOOGLE_APPLICATION_CREDENTIALS=

# Firebase Storage (document uploads)
FIREBASE_STORAGE_BUCKET=

# Firebase Client (browser — PUBLIC_ prefix required for Astro)
PUBLIC_FIREBASE_API_KEY=
PUBLIC_FIREBASE_AUTH_DOMAIN=
PUBLIC_FIREBASE_PROJECT_ID=
PUBLIC_FIREBASE_APP_ID=
PUBLIC_FIREBASE_MESSAGING_SENDER_ID=
PUBLIC_FIREBASE_STORAGE_BUCKET=

# Site URL for canonical/OG links (production)
PUBLIC_SITE_URL=

# Google Generative AI (Gemini text + Imagen hero images)
GOOGLE_GENERATIVE_AI_API_KEY=

# Cloud Functions — catalog PDF extraction (set via: firebase functions:secrets:set GEMINI_API_KEY)
GEMINI_API_KEY=
