---
import { db } from '../../lib/firebase-admin';
import { requireSellerOrRedirect } from '../../lib/auth';
import { getApparelCatalogForSeller } from '../../lib/clothing-api';
import AccountUidBanner from '../../components/AccountUidBanner.astro';
import '../../styles/global.css';

const seller = await requireSellerOrRedirect(Astro.request, Astro.cookies);
if (seller instanceof Response) return seller;

const [vehicleSnapshot, apparelCount] = await Promise.all([
  db().collection('vehicles').where('sellerId', '==', seller.uid).get(),
  getApparelCatalogForSeller(seller.uid)
    .then((catalog) => catalog.length)
    .catch(() => 0),
]);

const vehicleCount = vehicleSnapshot.size;
const displayEmail = seller.email ?? 'Seller';
---

<html lang="en">
  <head>
    <meta charset="utf-8" />
    <link rel="icon" type="image/svg+xml" href="/favicon.svg" />
    <link rel="icon" href="/favicon.ico" />
    <meta name="viewport" content="width=device-width" />
    <meta name="generator" content={Astro.generator} />
    <title>Seller Dashboards · Sell By Owner Local</title>
  </head>
  <body class="min-h-screen bg-[#f8f9fa] font-sans text-slate-900">
    <header class="bg-slate-900 text-white">
      <div class="mx-auto max-w-3xl px-4 py-10 sm:px-6">
        <h1 class="text-2xl font-bold">{displayEmail}</h1>
        <p class="mt-2 text-sm text-slate-400">Choose a dashboard to manage your listings</p>
      </div>
    </header>

    <main class="mx-auto max-w-3xl px-4 py-10 sm:px-6">
      <AccountUidBanner uid={seller.uid} />

      <div class="grid grid-cols-1 gap-6 md:grid-cols-2">
        <a
          href="/seller/vehicles"
          class="group block rounded-xl border border-slate-200 bg-white p-6 shadow-sm transition-colors hover:border-slate-300 hover:shadow-md"
        >
          <div class="flex items-start justify-between gap-4">
            <div>
              <h2 class="text-lg font-bold text-slate-900 group-hover:text-red-600 transition-colors">
                Vehicle Dashboard
              </h2>
              <p class="mt-2 text-sm text-slate-500">
                Manage vehicle listings, inquiries, and seller tools
              </p>
              <p class="mt-3 text-xs font-medium text-slate-400">
                {vehicleCount} {vehicleCount === 1 ? 'listing' : 'listings'}
              </p>
            </div>
            <span class="text-red-600 text-xl shrink-0" aria-hidden="true">→</span>
          </div>
        </a>

        <a
          href="/seller/apparel"
          class="group block rounded-xl border border-slate-200 bg-white p-6 shadow-sm transition-colors hover:border-slate-300 hover:shadow-md"
        >
          <div class="flex items-start justify-between gap-4">
            <div>
              <h2 class="text-lg font-bold text-slate-900 group-hover:text-red-600 transition-colors">
                Apparel Dashboard
              </h2>
              <p class="mt-2 text-sm text-slate-500">
                Manage clothing catalog, uploads, and buyer inquiries
              </p>
              <p class="mt-3 text-xs font-medium text-slate-400">
                {apparelCount} {apparelCount === 1 ? 'item' : 'items'}
              </p>
            </div>
            <span class="text-red-600 text-xl shrink-0" aria-hidden="true">→</span>
          </div>
        </a>
      </div>

      <div class="mt-10 flex flex-wrap items-center justify-center gap-6 text-sm">
        <a href="/account" class="font-semibold text-slate-600 hover:text-slate-900">
          Account settings
        </a>
        <a href="/" class="font-semibold text-red-600 hover:text-red-700">
          View marketplace →
        </a>
      </div>
    </main>
  </body>
</html>
