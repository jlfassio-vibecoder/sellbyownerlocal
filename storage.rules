rules_version = '2';
service firebase.storage {
  match /b/{bucket}/o {
    match /catalogs/{sellerId}/{fileName} {
      allow read: if request.auth != null && request.auth.uid == sellerId;
      allow write: if request.auth != null
        && request.auth.uid == sellerId
        && request.resource.contentType == 'application/pdf'
        && request.resource.size < 50 * 1024 * 1024;
    }
    match /apparel-images/staging/{sellerId}/{fileName} {
      allow read: if true;
      allow write: if request.auth != null
        && request.auth.uid == sellerId
        && request.resource.contentType.matches('image/.*')
        && request.resource.size < 10 * 1024 * 1024;
    }
    match /apparel-images/{sellerId}/{allPaths=**} {
      allow read: if true;
      allow write: if request.auth != null && request.auth.uid == sellerId;
    }
    match /{allPaths=**} {
      allow read, write: if false;
    }
  }
}
