---
import Layout from '../layouts/Layout.astro';
import { getOptionalSellerSession } from '../lib/auth';
import BuyerMarketplaceNav from '../islands/buyer/BuyerMarketplaceNav';

const session = await getOptionalSellerSession(Astro.request, Astro.cookies);
const displayName = session?.email?.split('@')[0] ?? 'there';
---

<Layout
  title="About · Sell By Owner Local"
  description="About Sell By Owner Local — a private-party marketplace for vehicles and local goods."
  ogUrl="/about"
>
  <BuyerMarketplaceNav client:load isLoggedIn={!!session} displayName={displayName} />

  <main class="mx-auto max-w-3xl px-4 py-16 sm:px-6 lg:px-8">
    <h1 class="text-3xl font-bold text-slate-900">About</h1>
    <p class="mt-4 text-lg text-slate-600">
      Content coming soon. Sell By Owner Local is building a professionalized private market for
      vehicles and local categories.
    </p>
    <p class="mt-8">
      <a href="/" class="font-semibold text-slate-900 underline underline-offset-2">
        Back to home
      </a>
    </p>
  </main>
</Layout>
