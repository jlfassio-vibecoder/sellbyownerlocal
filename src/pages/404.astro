---
import Layout from '../layouts/Layout.astro';

Astro.response.status = 404;
---

<Layout
  title="Page Not Found · Sell By Owner Local"
  description="The page or listing you are looking for could not be found."
  bodyClass="min-h-screen bg-[#f8f9fa] font-sans text-slate-900"
>
  <main class="mx-auto flex min-h-screen max-w-lg flex-col items-center justify-center px-4 py-16 text-center">
    <h1 class="text-3xl font-bold text-slate-900">Listing not found</h1>
    <p class="mt-3 text-slate-600">
      This apparel item may have been removed or is no longer available.
    </p>
    <a
      href="/marketplace/clothing"
      class="mt-8 inline-flex items-center rounded-lg bg-red-600 px-5 py-3 text-sm font-semibold text-white shadow-sm transition-colors hover:bg-red-700"
    >
      Browse Clothing Catalog
    </a>
  </main>
</Layout>
