---
import Layout from '../../../layouts/Layout.astro';
import { getClothingInventory } from '../../../lib/clothing-api';
import { priceFormatter } from '../../../utils/formatters';

const listings = await getClothingInventory();
---

<Layout
  title="Clothing & Apparel · Sell By Owner Local"
  description="Browse local clothing and apparel from independent reps. Frictionless, local deals beyond automotive."
>
  <header class="border-b border-slate-200 bg-white">
    <div class="mx-auto max-w-7xl px-4 py-8 sm:px-6 sm:py-10 lg:px-8 lg:py-12">
      <a
        href="/"
        class="mb-6 inline-flex items-center text-sm font-semibold text-red-600 hover:text-red-700"
      >
        ← Back to home
      </a>
      <div class="flex items-center gap-5 sm:gap-6">
        <a href="/" class="shrink-0" aria-label="Sell By Owner Local home">
          <img
            src="/images/logo.png"
            alt="Sell By Owner Local"
            class="h-[4.5rem] w-auto sm:h-[5.4rem]"
          />
        </a>
        <div>
          <h1 class="font-brand text-4xl leading-none text-slate-900 uppercase sm:text-5xl">
            Clothing & Apparel
          </h1>
          <p class="mt-2 text-base text-slate-500 sm:text-lg">
            Local fashion from independent reps
          </p>
        </div>
      </div>
    </div>
  </header>

  <main class="mx-auto max-w-7xl px-4 py-8 sm:px-6 lg:px-8">
    {
      listings.length > 0 ? (
        <>
          <p class="mb-6 text-sm text-slate-500">
            {listings.length} item{listings.length === 1 ? '' : 's'}
          </p>
          <div class="grid grid-cols-1 gap-6 sm:grid-cols-2 lg:grid-cols-3">
            {listings.map((listing) => (
              <a
                href={`/marketplace/clothing/${listing.id}`}
                class="block overflow-hidden rounded-xl border border-slate-200 bg-white shadow-sm transition-shadow hover:shadow-lg"
              >
                {listing.galleryPhotos[0] ? (
                  <img
                    src={listing.galleryPhotos[0]}
                    alt={listing.title}
                    class="aspect-[4/5] w-full object-cover"
                    loading="lazy"
                  />
                ) : (
                  <div class="flex aspect-[4/5] w-full items-center justify-center bg-slate-100 text-sm text-slate-500">
                    No photo
                  </div>
                )}
                <div class="space-y-3 p-4">
                  <p class="text-xs font-semibold uppercase tracking-wide text-slate-500">
                    {listing.brand}
                  </p>
                  <h2 class="text-xl font-bold text-slate-900">{listing.title}</h2>
                  <p class="text-xl font-bold text-slate-900">
                    {priceFormatter.format(listing.price)}
                  </p>
                  {listing.sizes.length > 0 && (
                    <ul class="flex flex-wrap gap-1.5">
                      {listing.sizes.map((size) => (
                        <li class="rounded-full bg-slate-100 px-2.5 py-0.5 text-xs text-slate-600">
                          {size}
                        </li>
                      ))}
                    </ul>
                  )}
                </div>
              </a>
            ))}
          </div>
        </>
      ) : (
        <div class="rounded-xl border border-dashed border-slate-300 bg-white p-12 text-center">
          <p class="text-lg font-medium text-slate-700">No clothing listed yet</p>
          <p class="mt-2 text-sm text-slate-500">
            Check back soon for local apparel from independent reps.
          </p>
        </div>
      )
    }
  </main>
</Layout>
