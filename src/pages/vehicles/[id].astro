---
import { db } from '../../lib/firebase-admin';
import { VehicleResponseSchema } from '../../schemas';
import { buildVehicleListingView } from '../../lib/vehicle-listing-view';
import { resolveVehicleDisplayMonroney } from '../../lib/resolve-display-monroney';
import VehicleListingContent from '../../components/VehicleListingContent.astro';
import '../../styles/global.css';

const { id } = Astro.params;

if (!id) {
  return new Response('Vehicle not found', { status: 404, statusText: 'Not Found' });
}

const doc = await db().collection('vehicles').doc(id).get();

if (!doc.exists) {
  return new Response('Vehicle not found', { status: 404, statusText: 'Not Found' });
}

const parsed = VehicleResponseSchema.safeParse({ id: doc.id, ...doc.data() });

if (!parsed.success) {
  if (import.meta.env.DEV) {
    console.error(`Vehicle ${id} failed validation:`, parsed.error.flatten());
  }
  return new Response('Vehicle not found', { status: 404, statusText: 'Not Found' });
}

const vehicle = parsed.data;
// Copilot suggestion ignored: SSR enrichment for derived Monroney only; caching belongs in a follow-up when write paths persist enriched data.
const displayMonroney = await resolveVehicleDisplayMonroney(vehicle);
const listingVehicle = displayMonroney ? { ...vehicle, monroney: displayMonroney } : vehicle;
const { pageTitle, descriptionExcerpt } = buildVehicleListingView(listingVehicle);
---

<html lang="en">
  <head>
    <meta charset="utf-8" />
    <link rel="icon" type="image/svg+xml" href="/favicon.svg" />
    <link rel="icon" href="/favicon.ico" />
    <meta name="viewport" content="width=device-width" />
    <meta name="generator" content={Astro.generator} />
    <meta name="description" content={descriptionExcerpt} />
    <title>{pageTitle} · Sell By Owner Local</title>
  </head>
  <body class="min-h-screen bg-[#f8f9fa] font-sans text-slate-900">
    <VehicleListingContent vehicle={listingVehicle} />
  </body>
</html>
