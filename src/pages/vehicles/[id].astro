---
import { z } from 'zod';
import { db } from '../../lib/firebase-admin';
import { VehicleResponseSchema } from '../../schemas';
import { getOptionalSession } from '../../lib/auth';
import { resolveVehicleDisplayMonroney } from '../../lib/resolve-display-monroney';
import {
  buildVehicleSeoDescription,
  buildVehicleSeoTitle,
  DEFAULT_OG_IMAGE,
  resolveVehicleOgImage,
} from '../../lib/seo';
import Layout from '../../layouts/Layout.astro';
import VehicleListingContent from '../../components/VehicleListingContent.astro';
import { generateVehicleSlug, resolveFirestoreIdCandidates } from '../../utils/url-helpers';

const { id } = Astro.params;

if (!id) {
  return new Response('Vehicle not found', { status: 404, statusText: 'Not Found' });
}

const slug = id;
let doc = null;

for (const candidate of resolveFirestoreIdCandidates(slug)) {
  const snapshot = await db().collection('vehicles').doc(candidate).get();
  if (snapshot.exists) {
    doc = snapshot;
    break;
  }
}

if (!doc) {
  return new Response('Vehicle not found', { status: 404, statusText: 'Not Found' });
}

const parsed = VehicleResponseSchema.safeParse({ id: doc.id, ...doc.data() });

if (!parsed.success) {
  if (import.meta.env.DEV) {
    console.error(`Vehicle ${slug} failed validation:`, z.flattenError(parsed.error));
  }
  return new Response('Vehicle not found', { status: 404, statusText: 'Not Found' });
}

const vehicle = parsed.data;
const canonicalSlug = generateVehicleSlug(vehicle);

if (slug !== canonicalSlug) {
  return Astro.redirect(`/vehicles/${canonicalSlug}`, 301);
}

const displayMonroney = await resolveVehicleDisplayMonroney(vehicle);
const listingVehicle = displayMonroney ? { ...vehicle, monroney: displayMonroney } : vehicle;

const seoTitle = buildVehicleSeoTitle(listingVehicle);
const seoDescription = buildVehicleSeoDescription(listingVehicle);
const seoImage = resolveVehicleOgImage(listingVehicle) ?? DEFAULT_OG_IMAGE;
const canonicalUrl = `/vehicles/${canonicalSlug}`;

const session = await getOptionalSession(Astro.request, Astro.cookies);

let initialSaved = false;
if (session) {
  const saveDoc = await db()
    .collection('saved_vehicles')
    .doc(`${session.uid}_${vehicle.id}`)
    .get();
  initialSaved = saveDoc.exists;
}

const buyerContext = {
  isLoggedIn: !!session,
  verificationTier: session?.verificationTier ?? 'anonymous',
  loginHref: `/login?next=${encodeURIComponent(
    vehicle.inventorySource === 'dealer_comp' ? canonicalUrl : `${canonicalUrl}#contact`
  )}`,
  saveLoginHref: `/login?next=${encodeURIComponent(canonicalUrl)}`,
};
const isVehicleOwner = Boolean(session?.uid && session.uid === vehicle.sellerId);
---

<Layout
  title={`${seoTitle} · Sell By Owner Local`}
  description={seoDescription}
  ogImage={seoImage}
  ogUrl={canonicalUrl}
  bodyClass="min-h-screen bg-[#f8f9fa] font-sans text-slate-900"
>
  <VehicleListingContent
    vehicle={listingVehicle}
    buyerContext={buyerContext}
    initialSaved={initialSaved}
    isVehicleOwner={isVehicleOwner}
  />
</Layout>
