---
import type { ClothingListing } from '../../../schemas';
import { requireSellerOrRedirect } from '../../../lib/auth';
import { getApparelCatalogForSeller } from '../../../lib/clothing-api';
import ApparelSellerLayout from '../../../islands/seller/ApparelSellerLayout';
import CatalogUploader from '../../../islands/seller/CatalogUploader';
import BulkImageUploader from '../../../islands/seller/BulkImageUploader';
import '../../../styles/global.css';

const seller = await requireSellerOrRedirect(Astro.request, Astro.cookies);
if (seller instanceof Response) return seller;

const catalog = await getApparelCatalogForSeller(seller.uid);

const wholesalePriceFormatter = new Intl.NumberFormat('en-US', {
  style: 'currency',
  currency: 'USD',
  minimumFractionDigits: 2,
});

const statusStyles: Record<ClothingListing['status'], string> = {
  draft: 'bg-amber-100 text-amber-800',
  active: 'bg-green-100 text-green-800',
  archived: 'bg-slate-100 text-slate-700',
};

const statusLabels: Record<ClothingListing['status'], string> = {
  draft: 'Draft',
  active: 'Active',
  archived: 'Archived',
};
---

<html lang="en">
  <head>
    <meta charset="utf-8" />
    <link rel="icon" type="image/svg+xml" href="/favicon.svg" />
    <link rel="icon" href="/favicon.ico" />
    <meta name="viewport" content="width=device-width" />
    <meta name="generator" content={Astro.generator} />
    <title>My Catalog · Apparel Dashboard · Sell By Owner Local</title>
  </head>
  <body class="min-h-screen bg-[#f8f9fa] font-sans text-slate-900">
    <ApparelSellerLayout client:load activeNav="catalog" sellerUid={seller.uid}>
      <div class="flex-1 overflow-y-auto">
        <div class="mx-auto max-w-6xl px-4 py-8 sm:px-6">
          <div class="mb-8 flex flex-wrap items-end justify-between gap-4">
            <div>
              <h2 class="text-2xl font-bold text-slate-900">My Catalog</h2>
              <p class="mt-1 text-sm text-slate-500">Select an item to manage</p>
            </div>
            <a
              href="/seller/apparel/new"
              class="inline-flex items-center rounded-lg bg-red-600 px-4 py-2.5 text-sm font-semibold text-white shadow-sm transition-colors hover:bg-red-700"
            >
              Add Catalog Item
            </a>
          </div>

          <CatalogUploader client:load sellerId={seller.uid} />

          <BulkImageUploader client:load sellerId={seller.uid} />

          {
            catalog.length === 0 ? (
              <div class="rounded-xl border border-dashed border-slate-300 bg-white p-12 text-center">
                <p class="text-lg font-medium text-slate-700">No catalog items yet</p>
                <p class="mt-2 text-sm text-slate-500">
                  Your apparel listings will appear here once added to your catalog.
                </p>
                <a
                  href="/seller/apparel/new"
                  class="mt-6 inline-flex items-center rounded-lg bg-red-600 px-4 py-2.5 text-sm font-semibold text-white shadow-sm transition-colors hover:bg-red-700"
                >
                  Add Catalog Item
                </a>
                <a
                  href="/marketplace/clothing"
                  class="mt-4 block text-sm font-semibold text-red-600 hover:text-red-700"
                >
                  Browse public apparel marketplace →
                </a>
              </div>
            ) : (
              <div class="grid grid-cols-1 gap-6 sm:grid-cols-2">
                {catalog.map((item) => (
                  <a
                    href={`/seller/apparel/${item.id}`}
                    class="block overflow-hidden rounded-xl border border-slate-200 bg-white shadow-sm transition-colors hover:border-slate-300 hover:shadow-md"
                  >
                    {item.galleryPhotos[0] ? (
                      <img
                        src={item.galleryPhotos[0]}
                        alt={item.title}
                        loading="lazy"
                        decoding="async"
                        class="aspect-[4/3] w-full object-cover"
                      />
                    ) : (
                      <div class="flex aspect-[4/3] w-full items-center justify-center bg-slate-200 text-sm text-slate-500">
                        No photo
                      </div>
                    )}
                    <div class="space-y-2 p-5">
                      <div class="flex items-start justify-between gap-3">
                        <div class="min-w-0">
                          <p class="text-xs font-semibold uppercase tracking-wide text-slate-500">
                            {item.brand}
                          </p>
                          <h3 class="text-lg font-bold text-slate-900">{item.title}</h3>
                        </div>
                        <span
                          class={`shrink-0 rounded-full px-2.5 py-0.5 text-xs font-semibold ${statusStyles[item.status]}`}
                        >
                          {statusLabels[item.status]}
                        </span>
                      </div>
                      <p class="text-lg font-semibold text-slate-900">
                        {wholesalePriceFormatter.format(item.price)}
                      </p>
                    </div>
                  </a>
                ))}
              </div>
            )
          }
        </div>
      </div>
    </ApparelSellerLayout>
  </body>
</html>
