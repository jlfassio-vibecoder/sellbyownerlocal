rules_version = '2';
service firebase.storage {
  match /b/{bucket}/o {
    match /catalogs/{sellerId}/{fileName} {
      allow read: if request.auth != null && request.auth.uid == sellerId;
      allow write: if request.auth != null
        && request.auth.uid == sellerId
        && request.resource.contentType == 'application/pdf'
        && request.resource.size < 50 * 1024 * 1024;
    }
    match /apparel-images/staging/{sellerId}/{fileName} {
      // Copilot suggestion applied: staging drafts are seller-readable only (not world-readable).
      allow read: if request.auth != null && request.auth.uid == sellerId;
      allow write: if request.auth != null
        && request.auth.uid == sellerId
        && request.resource.contentType.matches('image/.*')
        && request.resource.size < 10 * 1024 * 1024;
    }
    match /apparel-images/{sellerId}/{allPaths=**} {
      allow read: if true;
      allow write: if request.auth != null
        && request.auth.uid == sellerId
        && request.resource.contentType.matches('image/.*')
        && request.resource.size < 10 * 1024 * 1024;
    }
    match /apparel-pdfs/{sellerId}/{allPaths=**} {
      // Copilot suggestion ignored: public read matches apparel-images; buyer Open links use direct storage URLs.
      allow read: if true;
      allow write: if request.auth != null
        && request.auth.uid == sellerId
        && request.resource.contentType == 'application/pdf'
        && request.resource.size < 50 * 1024 * 1024;
    }
    match /storefront-heroes/{userId}/{imageId} {
      allow read: if true;
      allow write: if request.auth != null
                   && request.auth.uid == userId
                   && request.resource.size < 10 * 1024 * 1024
                   && request.resource.contentType.matches('image/.*');
    }
    match /{allPaths=**} {
      allow read, write: if false;
    }
  }
}
