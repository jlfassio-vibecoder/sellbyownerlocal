---
import Layout from '../../../../layouts/Layout.astro';
import { getOptionalSellerSession } from '../../../../lib/auth';
import { resolveSellerByStorefrontParam } from '../../../../lib/buyer-profile';
import { getActiveApparelForSeller } from '../../../../lib/clothing-api';
import ClothingInventoryGrid from '../../../../islands/buyer/ClothingInventoryGrid';
import {
  getStorefrontPath,
  resolveStorefrontSegment,
} from '../../../../utils/url-helpers';

const { storefrontSlug: param } = Astro.params;

if (!param) {
  return Astro.rewrite('/404');
}

const seller = await resolveSellerByStorefrontParam(param);
if (!seller) {
  return Astro.rewrite('/404');
}

const canonicalSegment = resolveStorefrontSegment(seller);
if (param !== canonicalSegment) {
  return Astro.redirect(getStorefrontPath(canonicalSegment), 301);
}

const listings = await getActiveApparelForSeller(seller.id);
const storefrontSegmentsBySellerId = { [seller.id]: canonicalSegment };

const session = await getOptionalSellerSession(Astro.request, Astro.cookies);
const buyerContext = {
  isLoggedIn: !!session,
  verificationTier: session?.verificationTier ?? 'anonymous',
};

const storefrontPath = getStorefrontPath(canonicalSegment);
const pageTitle = `${seller.displayName} · Apparel Storefront · Sell By Owner Local`;
const pageDescription = `Shop active wholesale apparel from ${seller.displayName} on Sell By Owner Local.`;
---

<Layout
  title={pageTitle}
  description={pageDescription}
  ogUrl={storefrontPath}
  bodyClass="min-h-screen bg-[#f8f9fa] font-sans text-slate-900"
>
  <header class="border-b border-slate-200 bg-white">
    <div class="mx-auto max-w-7xl px-4 py-8 sm:px-6 sm:py-10 lg:px-8 lg:py-12">
      <a
        href="/marketplace/clothing"
        class="mb-4 inline-flex items-center text-sm font-semibold text-red-600 hover:text-red-700"
      >
        ← Browse all apparel
      </a>
      <h1 class="font-brand text-4xl leading-none text-slate-900 uppercase sm:text-5xl">
        {seller.displayName}
      </h1>
      <p class="mt-2 text-base text-slate-500 sm:text-lg">Apparel storefront</p>
    </div>
  </header>

  {
    listings.length > 0 ? (
      <ClothingInventoryGrid
        client:load
        initialListings={listings}
        storefrontSegmentsBySellerId={storefrontSegmentsBySellerId}
        buyerContext={buyerContext}
      />
    ) : (
      <main class="mx-auto max-w-7xl px-4 py-8 sm:px-6 lg:px-8">
        <div class="rounded-xl border border-dashed border-slate-300 bg-white p-12 text-center">
          <p class="text-lg font-medium text-slate-700">This storefront has no active listings</p>
          <p class="mt-2 text-sm text-slate-500">
            Check back soon, or browse other apparel on the marketplace.
          </p>
          <a
            href="/marketplace/clothing"
            class="mt-6 inline-flex items-center rounded-lg bg-red-600 px-5 py-2.5 text-sm font-semibold text-white shadow-sm transition-colors hover:bg-red-700"
          >
            Browse all apparel
          </a>
        </div>
      </main>
    )
  }
</Layout>
