---
import { getStorefrontSegmentForSeller } from '../../../lib/buyer-profile';
import { getClothingListingById } from '../../../lib/clothing-api';
import { getClothingListingPath } from '../../../utils/url-helpers';

const { id } = Astro.params;

if (!id) {
  return new Response('Listing not found', { status: 404, statusText: 'Not Found' });
}

const listing = await getClothingListingById(id);

if (!listing) {
  return new Response('Listing not found', { status: 404, statusText: 'Not Found' });
}

const resolvedSegment = await getStorefrontSegmentForSeller(listing.sellerId);
return Astro.redirect(getClothingListingPath(id, resolvedSegment), 301);
---
