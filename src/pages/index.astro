---
import Layout from '../layouts/Layout.astro';
import { getOptionalSellerSession } from '../lib/auth';
import { getPublishedInventory } from '../lib/inventory-api';
import InventoryGrid from '../islands/buyer/InventoryGrid';
import VehicleMarketplaceHeader from '../components/vehicles/VehicleMarketplaceHeader.astro';
import VehicleMarketplaceHero from '../components/vehicles/VehicleMarketplaceHero.astro';

const session = await getOptionalSellerSession(Astro.request, Astro.cookies);
const displayName = session?.email?.split('@')[0] ?? 'there';
const vehicles = await getPublishedInventory();
const buyerContext = {
  isLoggedIn: !!session,
  verificationTier: session?.verificationTier ?? 'anonymous',
};
---

<Layout>
  <VehicleMarketplaceHeader />
  <VehicleMarketplaceHero session={session} displayName={displayName} />

  <section id="inventory">
    {
      vehicles.length > 0 ? (
        <InventoryGrid client:load initialVehicles={vehicles} buyerContext={buyerContext} />
      ) : (
        <main class="mx-auto max-w-7xl px-4 py-8 sm:px-6 lg:px-8">
          <div class="rounded-xl border border-dashed border-slate-300 bg-white p-12 text-center">
            <p class="text-lg font-medium text-slate-700">No vehicles listed yet</p>
            <p class="mt-2 text-sm text-slate-500">
              In development, seed sample data by visiting{' '}
              <a href="/api/dev/seed" class="rounded bg-slate-100 px-1.5 py-0.5 text-xs underline">
                /api/dev/seed
              </a>
            </p>
          </div>
        </main>
      )
    }
  </section>

  <section class="border-t border-slate-200 bg-white py-16">
    <div class="mx-auto max-w-7xl px-4 sm:px-6 lg:px-8">
      <h2 class="text-3xl font-bold text-slate-900">Explore Local Categories</h2>
      <p class="mt-2 text-slate-500">Frictionless, local deals beyond automotive.</p>

      <div class="mx-auto mt-8 grid max-w-7xl grid-cols-1 gap-6 px-4 sm:grid-cols-2 md:grid-cols-3">
        <a
          href="/vehicles"
          class="group block overflow-hidden rounded-xl border border-slate-200 bg-white shadow-sm transition-shadow hover:shadow-lg"
        >
          <div class="flex h-32 items-center justify-center bg-gradient-to-br from-slate-100 to-sky-100">
            <svg
              xmlns="http://www.w3.org/2000/svg"
              class="h-12 w-12 text-slate-600 transition-colors group-hover:text-sky-600"
              fill="none"
              viewBox="0 0 24 24"
              stroke="currentColor"
              stroke-width="1.5"
              aria-hidden="true"
            >
              <path
                stroke-linecap="round"
                stroke-linejoin="round"
                d="M8.25 18.75a1.5 1.5 0 0 1-3 0m3 0a1.5 1.5 0 0 0-3 0m3 0h6m-9 0H3.375a1.125 1.125 0 0 1-1.125-1.125V14.25m17.25 4.5a1.5 1.5 0 0 1-3 0m3 0a1.5 1.5 0 0 0-3 0m3 0h1.125c.621 0 1.129-.504 1.09-1.124a17.902 17.902 0 0 0-3.213-9.193 2.056 2.056 0 0 0-1.58-.86H14.25M16.5 18.75h-2.25m0-11.177v-.958c0-.568-.422-1.048-.987-1.106a48.554 48.554 0 0 0-10.026 0 1.106 1.106 0 0 0-.987 1.106v7.635m12-6.677v6.677m0 4.5v-4.5m0 0h-12"
              ></path>
            </svg>
          </div>
          <div class="space-y-1 p-4">
            <h3 class="text-lg font-bold text-slate-900">Vehicles & Trucks</h3>
            <p class="text-sm text-slate-500">Browse owner-listed cars with zero dealer markup.</p>
          </div>
        </a>

        <a
          href="/marketplace/clothing"
          class="group block overflow-hidden rounded-xl border border-slate-200 bg-white shadow-sm transition-shadow hover:shadow-lg"
        >
          <div class="flex h-32 items-center justify-center bg-gradient-to-br from-rose-50 to-slate-100">
            <svg
              xmlns="http://www.w3.org/2000/svg"
              class="h-12 w-12 text-slate-600 transition-colors group-hover:text-rose-600"
              fill="none"
              viewBox="0 0 24 24"
              stroke="currentColor"
              stroke-width="1.5"
              aria-hidden="true"
            >
              <path
                stroke-linecap="round"
                stroke-linejoin="round"
                d="M15.75 10.5V6a3.75 3.75 0 1 0-7.5 0v4.5m11.356-1.993 1.263 12c.07.665-.45 1.243-1.119 1.243H4.25a1.125 1.125 0 0 1-1.12-1.243l1.264-12A1.125 1.125 0 0 1 5.513 7.5h12.974c.576 0 1.059.435 1.119 1.007ZM8.625 10.5a.375.375 0 1 1-.75 0 .375.375 0 0 1 .75 0Zm7.5 0a.375.375 0 1 1-.75 0 .375.375 0 0 1 .75 0Z"
              ></path>
            </svg>
          </div>
          <div class="space-y-1 p-4">
            <h3 class="text-lg font-bold text-slate-900">Clothing & Apparel</h3>
            <p class="text-sm text-slate-500">Local fashion and apparel from independent reps.</p>
            <span class="inline-block pt-1 text-sm font-semibold text-red-600 group-hover:text-red-700">
              Browse →
            </span>
          </div>
        </a>
      </div>
    </div>
  </section>
</Layout>
