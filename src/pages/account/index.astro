---
import { requireSellerOrRedirect } from '../../lib/auth';
import { getUserProfile } from '../../lib/buyer-profile';
import { getActiveApparelCountForSeller } from '../../lib/clothing-api';
import { listFavoritesForBuyer } from '../../lib/favorites-server';
import type { VerificationTier } from '../../schemas';
import AccountUidBanner from '../../components/AccountUidBanner.astro';
import AccountStorefrontBanner from '../../components/AccountStorefrontBanner.astro';
import VerificationTierBadge from '../../components/VerificationTierBadge.astro';
import AccountFavoritesGrid from '../../islands/buyer/AccountFavoritesGrid';
import BuyerInbox from '../../islands/buyer/BuyerInbox';
import ProfileEditor from '../../islands/buyer/ProfileEditor';
import PhoneOtpAccountVerify from '../../islands/PhoneOtpAccountVerify';
import SignOutButton from '../../islands/SignOutButton';
import { getStorefrontPath, resolveStorefrontSegment } from '../../utils/url-helpers';
import '../../styles/global.css';

const session = await requireSellerOrRedirect(Astro.request, Astro.cookies);
if (session instanceof Response) return session;

const profile = await getUserProfile(session.uid);
const verificationTier: VerificationTier = profile?.verificationTier ?? session.verificationTier;

const displayEmail = session.email ?? 'Your account';
const uid = session.uid;
const storefrontSegment = resolveStorefrontSegment({
  id: uid,
  storefrontSlug: profile?.storefrontSlug,
});
const storefrontPath = getStorefrontPath(storefrontSegment);
const hasCustomSlug = Boolean(profile?.storefrontSlug);
const activeListingCount = await getActiveApparelCountForSeller(uid);
const initialFavorites = await listFavoritesForBuyer(uid);

const showVerifyPhone = verificationTier === 'anonymous';
const showVerifyIdentity = verificationTier === 'phone_verified';
const showFullyVerified = verificationTier === 'identity_verified';
---

<html lang="en">
  <head>
    <meta charset="utf-8" />
    <link rel="icon" type="image/svg+xml" href="/favicon.svg" />
    <link rel="icon" href="/favicon.ico" />
    <meta name="viewport" content="width=device-width" />
    <meta name="generator" content={Astro.generator} />
    <title>Your Account · Sell By Owner Local</title>
  </head>
  <body class="min-h-screen bg-[#f8f9fa] font-sans text-slate-900">
    <header class="bg-slate-900 text-white">
      <div class="mx-auto max-w-3xl px-4 py-10 sm:px-6">
        <div class="mb-4 flex items-center justify-between gap-3">
          <a
            href="/vehicles"
            class="inline-flex items-center gap-1.5 text-sm font-semibold text-slate-300 transition-colors hover:text-white"
          >
            <svg
              xmlns="http://www.w3.org/2000/svg"
              viewBox="0 0 24 24"
              fill="none"
              stroke="currentColor"
              stroke-width="2"
              stroke-linecap="round"
              stroke-linejoin="round"
              class="h-4 w-4"
              aria-hidden="true"
            >
              <path d="M19 12H5"></path>
              <path d="m12 19-7-7 7-7"></path>
            </svg>
            Back
          </a>
          <SignOutButton client:load />
        </div>
        <h1 class="text-2xl font-bold">{displayEmail}</h1>
        <p class="mt-2 text-sm text-slate-400">Manage your marketplace account</p>
      </div>
    </header>

    <main class="mx-auto max-w-3xl px-4 py-10 sm:px-6">
      <AccountUidBanner uid={uid} />

      <section class="mb-8 rounded-xl border border-slate-200 bg-white p-6 shadow-sm">
        <div class="flex flex-wrap items-center justify-between gap-4">
          <div>
            <h2 class="text-lg font-bold text-slate-900">Verification Status</h2>
            <p class="mt-1 text-sm text-slate-500">
              Build trust with sellers by verifying your identity over time.
            </p>
          </div>
          <VerificationTierBadge tier={verificationTier} />
        </div>

        {
          showVerifyPhone && (
            <div
              id="verify-phone"
              class="mt-6 rounded-lg border border-dashed border-slate-200 bg-slate-50 p-4"
            >
              <p class="mb-4 text-sm text-slate-600">
                Verify your mobile number to send inquiries to sellers and back up favorites to the
                cloud.
              </p>
              <PhoneOtpAccountVerify client:load />
            </div>
          )
        }

        {
          showVerifyIdentity && (
            <div class="mt-6 flex flex-wrap items-center justify-between gap-4 rounded-lg border border-dashed border-slate-200 bg-slate-50 p-4">
              <p class="text-sm text-slate-600">
                Complete identity verification to schedule test drives and make offers.
              </p>
              <button
                type="button"
                disabled
                class="cursor-not-allowed rounded-lg bg-slate-200 px-4 py-2 text-sm font-semibold text-slate-500"
                title="Coming in Phase 6"
              >
                Verify identity
              </button>
            </div>
          )
        }

        {
          showFullyVerified && (
            <p class="mt-6 text-sm text-green-700">
              Your identity is verified. You can use high-stakes buyer actions when they become
              available.
            </p>
          )
        }
      </section>

      <section class="mb-8 rounded-xl border border-slate-200 bg-white p-6 shadow-sm">
        <h2 class="text-lg font-bold text-slate-900">Profile</h2>
        <p class="mt-1 mb-6 text-sm text-slate-500">Update how your name appears to sellers.</p>
        <ProfileEditor
          client:load
          mode="profile"
          userId={uid}
          displayName={profile?.displayName ?? ''}
          email={displayEmail}
        />
      </section>

      <section class="mb-8 rounded-xl border border-slate-200 bg-white p-6 shadow-sm">
        <h2 class="text-lg font-bold text-slate-900">Saved Vehicles</h2>
        <p class="mt-1 mb-6 text-sm text-slate-500">Vehicles you've favorited while browsing.</p>
        <AccountFavoritesGrid
          client:load
          isLoggedIn={true}
          verificationTier={verificationTier}
          initialItems={initialFavorites}
        />
      </section>

      <section class="mb-8 rounded-xl border border-slate-200 bg-white p-6 shadow-sm">
        <h2 class="text-lg font-bold text-slate-900">My Messages</h2>
        <p class="mt-1 mb-6 text-sm text-slate-500">
          Conversations with sellers about vehicles you're interested in.
        </p>
        <BuyerInbox client:load />
      </section>

      <section class="mb-8 rounded-xl border border-slate-200 bg-white p-6 shadow-sm">
        <h2 class="text-lg font-bold text-slate-900">Selling Tools</h2>
        <p class="mt-1 mb-6 text-sm text-slate-500">
          Manage listings, storefront branding, and seller settings.
        </p>

        <AccountStorefrontBanner
          storefrontPath={storefrontPath}
          hasCustomSlug={hasCustomSlug}
          activeListingCount={activeListingCount}
        />

        <a
          href="/seller"
          class="group mb-6 flex items-start justify-between gap-4 rounded-xl border border-slate-200 bg-slate-50 p-5 transition-colors hover:border-slate-300 hover:bg-white"
        >
          <div>
            <h3 class="text-base font-bold text-slate-900 transition-colors group-hover:text-red-600">
              Seller Dashboard
            </h3>
            <p class="mt-1 text-sm text-slate-500">Manage your vehicle listings and inquiries</p>
          </div>
          <span class="shrink-0 text-xl text-red-600" aria-hidden="true">→</span>
        </a>

        <div class="border-t border-slate-200 pt-6">
          <h3 class="mb-4 text-base font-bold text-slate-900">Storefront Settings</h3>
          <ProfileEditor
            client:load
            mode="storefront"
            userId={uid}
            displayName={profile?.displayName ?? ''}
            email={displayEmail}
            storefrontSlug={profile?.storefrontSlug}
            storefrontName={profile?.storefrontName}
            storefrontTagline={profile?.storefrontTagline}
            storefrontHeroUrl={profile?.storefrontHeroUrl}
          />
        </div>
      </section>

      <p class="mt-10 text-center">
        <a href="/vehicles" class="text-sm font-semibold text-red-600 hover:text-red-700">
          Browse listings →
        </a>
      </p>
    </main>
  </body>
</html>
