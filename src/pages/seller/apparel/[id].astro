---
import { requireSellerOrRedirect } from '../../../lib/auth';
import { getUserProfile } from '../../../lib/buyer-profile';
import { getApparelListingForSellerById } from '../../../lib/clothing-api';
import ApparelSellerLayout from '../../../islands/seller/ApparelSellerLayout';
import ApparelEditorForm from '../../../islands/seller/ApparelEditorForm';
import ApparelListingImage from '../../../components/apparel/ApparelListingImage';
import { getStorefrontPath, resolveStorefrontSegment } from '../../../utils/url-helpers';
import '../../../styles/global.css';

const seller = await requireSellerOrRedirect(Astro.request, Astro.cookies);
if (seller instanceof Response) return seller;

const { id } = Astro.params;

const listing = id ? await getApparelListingForSellerById(id, seller.uid) : null;

if (!listing) {
  return Astro.redirect('/seller/apparel');
}

const profile = await getUserProfile(seller.uid);
const storefrontHref = getStorefrontPath(
  resolveStorefrontSegment({
    id: seller.uid,
    storefrontSlug: profile?.storefrontSlug,
  })
);

const initialData = {
  id: listing.id,
  title: listing.title,
  brand: listing.brand,
  price: listing.price,
  description: listing.description,
  sizes: listing.sizes,
  material: listing.material,
  colors: listing.colors,
  prePackRatio: listing.prePackRatio,
  pdfLineSheetUrl: listing.pdfLineSheetUrl,
  pdfDefaultPage: listing.pdfDefaultPage,
  galleryPhotos: listing.galleryPhotos,
  status: listing.status,
  isFeatured: listing.isFeatured,
  isSale: listing.isSale,
  salePrice: listing.salePrice,
};

const heroImage = listing.galleryPhotos?.[0];
---

<html lang="en">
  <head>
    <meta charset="utf-8" />
    <link rel="icon" href="/favicon.ico" sizes="any" />
    <link rel="icon" type="image/png" href="/favicon.png" />
    <link rel="apple-touch-icon" href="/apple-touch-icon.png" />
    <meta name="viewport" content="width=device-width" />
    <meta name="generator" content={Astro.generator} />
    <title>{listing.title} · Apparel Dashboard · Sell By Owner Local</title>
  </head>
  <body class="min-h-screen bg-[#f8f9fa] font-sans text-slate-900">
    <ApparelSellerLayout client:load activeNav="catalog" storefrontHref={storefrontHref}>
      <div class="flex-1 overflow-y-auto">
        <div class="mx-auto max-w-6xl px-4 py-8 sm:px-6">
          <div class="mb-8">
            <a
              href="/seller/apparel"
              class="mb-4 inline-flex items-center text-sm font-semibold text-red-600 hover:text-red-700"
            >
              ← Back to catalog
            </a>
            <h2 class="text-2xl font-bold text-slate-900">Edit: {listing.title}</h2>
            <p class="mt-1 text-sm text-slate-500">Update wholesale details for this catalog item</p>
          </div>

          <ApparelListingImage
            title={listing.title}
            imageUrl={heroImage}
            className="mb-8 overflow-hidden rounded-xl border border-slate-200 bg-white shadow-sm"
          />

          <ApparelEditorForm client:load sellerId={seller.uid} initialData={initialData} />
        </div>
      </div>
    </ApparelSellerLayout>
  </body>
</html>
