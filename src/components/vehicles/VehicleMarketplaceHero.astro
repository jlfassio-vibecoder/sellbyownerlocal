---
import type { UserSession } from '../../lib/auth';
import AuthForm from '../../islands/AuthForm';

interface Props {
  session: UserSession | null;
  displayName: string;
}

const { session, displayName } = Astro.props;
---

<section class="relative overflow-hidden border-b border-slate-200">
  <div
    class="absolute inset-0 bg-cover bg-center bg-no-repeat"
    style="background-image: url('/images/sell-by-owner-local-hero-1.png')"
    aria-hidden="true"
  >
  </div>
  <div
    class="absolute inset-0 bg-gradient-to-r from-white/95 via-white/80 to-white/35"
    aria-hidden="true"
  >
  </div>

  <div
    class="relative z-10 mx-auto grid max-w-7xl grid-cols-1 items-center gap-12 px-4 py-16 sm:px-6 lg:grid-cols-2 lg:px-8 lg:py-20"
  >
    <div>
      <h1 class="text-5xl leading-tight font-extrabold tracking-tight text-slate-900 md:text-6xl lg:text-7xl">
        The Private Market,
        <br />
        <span class="font-semibold opacity-80">Professionalized.</span>
      </h1>
      <div class="mt-6 max-w-xl space-y-4 text-lg text-slate-700 md:text-xl">
        <p>
          <span class="font-bold">For Sellers:</span> Turn your car into a professional retail
          listing in less than a minute with just your VIN #.
        </p>
        <p>
          <span class="font-bold">For Buyers:</span> Browse owner-listed cars with zero dealer
          markup and 100% ID-verified transparency.
        </p>
      </div>
      <ul
        class="mt-8 flex list-none flex-wrap gap-x-6 gap-y-2 text-sm font-medium text-slate-600 italic md:text-base"
      >
        <li class="flex items-center gap-2 before:content-['•']">Direct from Owners</li>
        <li class="flex items-center gap-2 before:content-['•']">No Dealer Markup</li>
        <li class="flex items-center gap-2 before:content-['•']">Verified Identity Secure</li>
      </ul>
    </div>

    {
      session ? (
        <div class="mx-auto w-full max-w-md rounded-2xl border border-slate-100 bg-white/25 p-6 text-center shadow-xl backdrop-blur-sm sm:p-8">
          <p class="text-lg font-semibold text-slate-900">Welcome back, {displayName}</p>
          <p class="mt-2 text-sm text-slate-500">Ready to manage your listings?</p>
          <a
            href="/seller"
            class="mt-6 inline-block w-full rounded-lg bg-red-600 px-4 py-2.5 text-sm font-semibold text-white transition-colors hover:bg-red-700"
          >
            Go to Seller Dashboard
          </a>
          {
            session.isDealer && (
              <a
                href="/dealer/new"
                class="mt-3 inline-block w-full rounded-lg border border-slate-200 px-4 py-2.5 text-sm font-semibold text-slate-700 transition-colors hover:bg-slate-50"
              >
                New AI Listing
              </a>
            )
          }
          <a href="/account" class="mt-3 block text-sm font-semibold text-red-600 hover:text-red-700">
            Account settings
          </a>
        </div>
      ) : (
        <div id="hero-auth" class="mx-auto w-full max-w-md">
          <div class="rounded-2xl border border-slate-100 bg-white/95 p-6 shadow-xl backdrop-blur-sm sm:p-8">
            <AuthForm client:load embedded />
          </div>
          <p class="mt-4 px-2 text-center text-sm leading-relaxed text-slate-700">
            Create an account to become a verified buyer or seller—or browse listings and send
            inquiries anonymously without signing up.
          </p>
        </div>
      )
    }
  </div>
</section>
