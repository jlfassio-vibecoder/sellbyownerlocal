---
import { requireSellerOrRedirect } from '../../lib/auth';
import { getUserProfile } from '../../lib/buyer-profile';
import type { VerificationTier } from '../../schemas';
import AccountUidBanner from '../../components/AccountUidBanner.astro';
import AccountStorefrontBanner from '../../components/AccountStorefrontBanner.astro';
import VerificationTierBadge from '../../components/VerificationTierBadge.astro';
import ProfileEditor from '../../islands/buyer/ProfileEditor';
import PhoneOtpAccountVerify from '../../islands/PhoneOtpAccountVerify';
import { getStorefrontPath, resolveStorefrontSegment } from '../../utils/url-helpers';
import '../../styles/global.css';

const session = await requireSellerOrRedirect(Astro.request, Astro.cookies);
if (session instanceof Response) return session;

const profile = await getUserProfile(session.uid);
const verificationTier: VerificationTier = profile?.verificationTier ?? session.verificationTier;

const displayEmail = session.email ?? 'Your account';
const uid = session.uid;
const storefrontSegment = resolveStorefrontSegment({
  id: uid,
  storefrontSlug: profile?.storefrontSlug,
});
const storefrontPath = getStorefrontPath(storefrontSegment);
const hasCustomSlug = Boolean(profile?.storefrontSlug);

const showVerifyPhone = verificationTier === 'anonymous';
const showVerifyIdentity = verificationTier === 'phone_verified';
const showFullyVerified = verificationTier === 'identity_verified';
---

<html lang="en">
  <head>
    <meta charset="utf-8" />
    <link rel="icon" type="image/svg+xml" href="/favicon.svg" />
    <link rel="icon" href="/favicon.ico" />
    <meta name="viewport" content="width=device-width" />
    <meta name="generator" content={Astro.generator} />
    <title>Your Account · Sell By Owner Local</title>
  </head>
  <body class="min-h-screen bg-[#f8f9fa] font-sans text-slate-900">
    <header class="bg-slate-900 text-white">
      <div class="mx-auto max-w-3xl px-4 py-10 sm:px-6">
        <h1 class="text-2xl font-bold">{displayEmail}</h1>
        <p class="mt-2 text-sm text-slate-400">Manage your marketplace account</p>
      </div>
    </header>

    <main class="mx-auto max-w-3xl px-4 py-10 sm:px-6">
      <AccountUidBanner uid={uid} />
      <AccountStorefrontBanner storefrontPath={storefrontPath} hasCustomSlug={hasCustomSlug} />

      <section class="mb-8 rounded-xl border border-slate-200 bg-white p-6 shadow-sm">
        <h2 class="text-lg font-bold text-slate-900">Profile</h2>
        <p class="mt-1 mb-6 text-sm text-slate-500">Update how your name appears to sellers.</p>
        <ProfileEditor
          client:load
          userId={uid}
          displayName={profile?.displayName ?? ''}
          email={displayEmail}
          storefrontSlug={profile?.storefrontSlug}
          storefrontName={profile?.storefrontName}
          storefrontTagline={profile?.storefrontTagline}
          storefrontHeroUrl={profile?.storefrontHeroUrl}
        />
      </section>

      <section class="mb-8 rounded-xl border border-slate-200 bg-white p-6 shadow-sm">
        <div class="flex flex-wrap items-center justify-between gap-4">
          <div>
            <h2 class="text-lg font-bold text-slate-900">Verification Status</h2>
            <p class="mt-1 text-sm text-slate-500">
              Build trust with sellers by verifying your identity over time.
            </p>
          </div>
          <VerificationTierBadge tier={verificationTier} />
        </div>

        {
          showVerifyPhone && (
            <div
              id="verify-phone"
              class="mt-6 rounded-lg border border-dashed border-slate-200 bg-slate-50 p-4"
            >
              <p class="mb-4 text-sm text-slate-600">
                Verify your mobile number to send inquiries to sellers.
              </p>
              <PhoneOtpAccountVerify client:load />
            </div>
          )
        }

        {
          showVerifyIdentity && (
            <div class="mt-6 flex flex-wrap items-center justify-between gap-4 rounded-lg border border-dashed border-slate-200 bg-slate-50 p-4">
              <p class="text-sm text-slate-600">
                Complete identity verification to schedule test drives and make offers.
              </p>
              <button
                type="button"
                disabled
                class="cursor-not-allowed rounded-lg bg-slate-200 px-4 py-2 text-sm font-semibold text-slate-500"
                title="Coming in Phase 6"
              >
                Verify identity
              </button>
            </div>
          )
        }

        {
          showFullyVerified && (
            <p class="mt-6 text-sm text-green-700">
              Your identity is verified. You can use high-stakes buyer actions when they become
              available.
            </p>
          )
        }
      </section>

      <div class="grid grid-cols-1 gap-6 md:grid-cols-2">
        <a
          href="/seller"
          class="group block rounded-xl border border-slate-200 bg-white p-6 shadow-sm transition-colors hover:border-slate-300 hover:shadow-md"
        >
          <div class="flex items-start justify-between gap-4">
            <div>
              <h2 class="text-lg font-bold text-slate-900 group-hover:text-red-600 transition-colors">
                Seller Dashboard
              </h2>
              <p class="mt-2 text-sm text-slate-500">
                Manage your vehicle listings and inquiries
              </p>
            </div>
            <span class="text-red-600 text-xl shrink-0" aria-hidden="true">→</span>
          </div>
        </a>

        <div
          class="rounded-xl border border-slate-200 bg-white p-6 shadow-sm opacity-60 cursor-not-allowed"
          aria-disabled="true"
        >
          <div class="flex items-start justify-between gap-4">
            <div>
              <div class="flex items-center gap-2 flex-wrap">
                <h2 class="text-lg font-bold text-slate-900">Saved Vehicles</h2>
                <span class="bg-slate-100 text-slate-500 text-xs font-medium px-2.5 py-0.5 rounded-full">
                  Coming Soon
                </span>
              </div>
              <p class="mt-2 text-sm text-slate-500">View cars you've favorited</p>
            </div>
          </div>
        </div>
      </div>

      <p class="mt-10 text-center">
        <a href="/" class="text-sm font-semibold text-red-600 hover:text-red-700">
          Browse listings →
        </a>
      </p>
    </main>
  </body>
</html>
