---
import type { VehicleResponse, VerificationTier } from '../schemas';
import {
  buildVehicleListingView,
  canEmbedPdf,
  isPdfUrl,
  mileageFormatter,
  priceFormatter,
  specItems,
} from '../lib/vehicle-listing-view';
import { buildMonroneyStyleLineFromVehicle } from '../lib/monroney-style-line';
import { getAccent } from '../lib/accent-colors';
import ListingAnalytics from '../islands/ListingAnalytics';
import ImageCarousel from '../islands/ImageCarousel';
import ChatWidget from '../islands/ChatWidget';
import Gallery from '../islands/Gallery';
import MarketChart from '../islands/MarketChart';
import ContactForm from '../islands/ContactForm';
import VehicleSectionNav from '../islands/VehicleSectionNav';
import FavoriteButton from '../islands/buyer/FavoriteButton';
import WindowSticker from '../islands/WindowSticker';
import SingleDocumentViewer from '../islands/SingleDocumentViewer.tsx';
import HistoryReportViewer from '../islands/HistoryReportViewer.tsx';
import ServiceTimeline from '../islands/ServiceTimeline';
import AccentText from './AccentText';
import MarkdownText from './MarkdownText';
import { Check, Download } from 'lucide-react';

interface BuyerContext {
  isLoggedIn: boolean;
  verificationTier: VerificationTier;
  userEmail: string;
  userDisplayName: string;
  userPhone: string;
  loginHref: string;
  saveLoginHref?: string;
}

interface Props {
  vehicle: VehicleResponse;
  analyticsEnabled?: boolean;
  buyerContext?: BuyerContext;
  initialSaved?: boolean;
}

const { vehicle, analyticsEnabled = true, buyerContext, initialSaved = false } = Astro.props;
const view = buildVehicleListingView(vehicle);
const {
  pageTitle,
  descriptionExcerpt,
  heroImage,
  carouselImageUrls,
  marketImageUrls,
  primaryTag,
  otherDocuments,
  originalStickerUrl,
  kbbReportUrl,
  smogCertificateUrls,
  showGeneratedSticker,
  windowStickerBreakdown,
  monroney,
  showWindowStickerSection,
  showDocumentsSection,
  historyReportUrls,
  walkaroundVideoUrl,
  walkaroundPosterUrl,
  walkaroundYoutubeId,
  walkaroundVimeoId,
  sellersNote,
  pitchSubtitle,
  pitchIntro,
  originalMsrp,
  heroImagePending,
  pitchBlocks,
  ctaButtonLabel,
  navSections,
} = view;
const monroneyStyleLine = monroney
  ? buildMonroneyStyleLineFromVehicle(vehicle, monroney)
  : undefined;
const accent = getAccent(vehicle.accentColor);
const analyticsSectionIds = navSections.map((section) => section.id);
const favoriteTitle =
  vehicle.listingTitle?.trim() || `${vehicle.year} ${vehicle.make} ${vehicle.model}`;
---

{
  analyticsEnabled && (
    <ListingAnalytics
      client:load
      vehicleId={vehicle.id}
      sectionIds={analyticsSectionIds}
    />
  )
}

<VehicleSectionNav
  client:load
  pageTitle={pageTitle}
  vin={vehicle.vin}
  locationCity={vehicle.location.city}
  accentColor={vehicle.accentColor}
  sections={navSections}
  saveVehicle={
    buyerContext
      ? {
          vehicleId: vehicle.id,
          isLoggedIn: buyerContext.isLoggedIn,
          verificationTier: buyerContext.verificationTier,
          loginHref: buyerContext.saveLoginHref ?? buyerContext.loginHref,
          initialSaved,
        }
      : undefined
  }
/>

<main class="relative mx-auto max-w-6xl px-4 py-8 sm:px-6 lg:px-8">
  <section id="overview" class="mb-16 pt-8">
    <div class="grid grid-cols-1 items-center gap-12 lg:grid-cols-2">
      <div class="flex flex-col gap-6">
        <h1 class="text-4xl leading-tight font-bold text-slate-900 md:text-5xl">
          {
            vehicle.listingTitle?.trim() ? (
              <AccentText
                text={vehicle.listingTitle.trim()}
                accentClass={accent.tailwindText}
              />
            ) : (
              <>
                {vehicle.year} {vehicle.make}{' '}
                <AccentText text={vehicle.model} accentClass={accent.tailwindText} />
              </>
            )
          }
        </h1>

        <div class="inline-block w-max rounded-2xl border border-slate-800 bg-slate-900 p-5 shadow-lg">
          <p class="mb-1 text-sm font-semibold tracking-wider text-slate-400 uppercase">
            Asking Price
          </p>
          <p class="text-4xl font-bold text-white md:text-5xl">
            <AccentText
              text={priceFormatter.format(vehicle.price)}
              accentClass={accent.tailwindText}
            />
          </p>
        </div>

        <p class="max-w-lg text-sm leading-relaxed text-slate-500">
          <AccentText text={descriptionExcerpt} accentClass={accent.tailwindText} />
        </p>

        <div class="grid grid-cols-2 gap-4">
          {
            vehicle.vin && (
              <div class="rounded-xl border border-slate-200 bg-white p-4 shadow-sm">
                <span class="mb-1 block text-[10px] font-bold text-slate-400 uppercase">
                  VIN Verified
                </span>
                <span class="text-sm font-semibold">{vehicle.vin}</span>
              </div>
            )
          }
          <div class="rounded-xl border border-slate-200 bg-white p-4 shadow-sm">
            <span class={`mb-1 block text-[10px] font-bold uppercase ${accent.tailwindText}`}>
              Drivetrain
            </span>
            <span class="text-sm font-semibold uppercase">{vehicle.specs.drivetrain}</span>
          </div>
        </div>

        <div class="grid grid-cols-2 gap-4">
          <div class="rounded-xl border border-slate-200 bg-white p-4 shadow-sm">
            <span class={`mb-1 block text-[10px] font-bold uppercase ${accent.tailwindText}`}>
              Mileage
            </span>
            <span class="text-sm font-semibold">
              {mileageFormatter.format(vehicle.mileage)} mi
            </span>
          </div>
          <div class="rounded-xl border border-slate-200 bg-white p-4 shadow-sm">
            <span class="mb-1 block text-[10px] font-bold text-slate-400 uppercase">
              Location
            </span>
            <span class="text-sm font-semibold">{vehicle.location.city}</span>
          </div>
        </div>
      </div>

      <div class="group relative h-80 w-full overflow-hidden rounded-2xl border border-slate-200 bg-slate-200 shadow-sm">
        <div class="absolute top-3 right-3 z-20">
          <FavoriteButton
            client:load
            itemId={vehicle.id}
            title={favoriteTitle}
            price={vehicle.price}
            category="vehicle"
            sellerId={vehicle.sellerId}
            isLoggedIn={buyerContext?.isLoggedIn ?? false}
            verificationTier={buyerContext?.verificationTier ?? 'anonymous'}
          />
        </div>
        {
          heroImage ? (
            <img
              src={heroImage}
              alt={pageTitle}
              class="absolute inset-0 h-full w-full object-cover"
            />
          ) : heroImagePending ? (
            <div class="absolute inset-0 flex items-center justify-center bg-slate-100 text-sm text-slate-600">
              Hero image generating…
            </div>
          ) : (
            <div class="absolute inset-0 flex items-center justify-center text-sm text-slate-500">
              No photo
            </div>
          )
        }
        <div class="absolute inset-0 z-10 flex items-end bg-gradient-to-t from-slate-900/90 via-slate-900/40 to-transparent p-6">
          <div class="flex w-full items-end justify-between text-white">
            <div>
              <h2 class="text-2xl font-bold drop-shadow-md">
                <AccentText text={pageTitle} accentClass={accent.tailwindText} />
              </h2>
              <p class="mt-1 text-sm text-slate-100 drop-shadow-md">
                Listed by {vehicle.sellerName}
              </p>
            </div>
            {
              primaryTag && (
                <span class="rounded border border-white/10 bg-black/40 px-3 py-1 text-xs font-semibold tracking-wider uppercase backdrop-blur">
                  {primaryTag}
                </span>
              )
            }
          </div>
        </div>
      </div>
    </div>
  </section>

  <ImageCarousel
    client:load
    images={carouselImageUrls}
    altPrefix={pageTitle}
    vehicleId={analyticsEnabled ? vehicle.id : undefined}
  />

  {
    walkaroundVideoUrl && (
      <section id="walkaround" class="mb-16 pt-4">
        <div class="overflow-hidden rounded-2xl border border-slate-200 bg-white p-6 text-center shadow-sm md:p-8">
          <h2 class="mb-4 text-2xl font-bold text-slate-900">Detailed Walkaround</h2>
          <p class="mx-auto mb-6 max-w-2xl text-slate-600">
            Take a closer look at the exterior, interior, and engine bay in this comprehensive
            walkaround video.
          </p>
          <div class="relative mx-auto aspect-video w-full max-w-4xl overflow-hidden rounded-xl border border-slate-200 bg-slate-900 shadow-lg">
            {walkaroundYoutubeId ? (
              <iframe
                src={`https://www.youtube.com/embed/${walkaroundYoutubeId}`}
                title="Vehicle walkaround video"
                class="absolute top-0 left-0 h-full w-full"
                allow="accelerometer; autoplay; clipboard-write; encrypted-media; gyroscope; picture-in-picture"
                allowfullscreen
                loading="lazy"
              />
            ) : walkaroundVimeoId ? (
              <iframe
                src={`https://player.vimeo.com/video/${walkaroundVimeoId}`}
                title="Vehicle walkaround video"
                class="absolute top-0 left-0 h-full w-full"
                allow="autoplay; fullscreen; picture-in-picture"
                allowfullscreen
                loading="lazy"
              />
            ) : (
              <video
                controls
                preload="none"
                poster={walkaroundPosterUrl}
                class="h-full w-full object-cover"
              >
                <source src={walkaroundVideoUrl} type="video/mp4" />
                Your browser does not support the video tag.
              </video>
            )}
          </div>
        </div>
      </section>
    )
  }

  <section id="pitch" class="mb-16 pt-8">
    <div class="overflow-hidden rounded-2xl border border-slate-200 bg-white shadow-sm">
      <div class="bg-slate-900 p-8 text-white md:p-10">
        <h2 class="mb-4 text-2xl font-bold md:text-3xl">Seller's Note</h2>
        <p class="max-w-3xl text-lg leading-snug font-semibold whitespace-pre-wrap text-slate-300 md:text-xl">
          {
            sellersNote ? (
              <AccentText text={pitchSubtitle} accentClass={accent.tailwindText} />
            ) : (
              `Listed by ${vehicle.sellerName}`
            )
          }
        </p>

        <div class="mt-6 flex flex-col gap-4 sm:flex-row sm:gap-8">
          <div class="rounded-xl border border-slate-700/50 bg-slate-800/50 p-4 backdrop-blur-sm">
            <p class="mb-1 text-xs font-semibold tracking-wider text-slate-400 uppercase">
              Asking Price
            </p>
            <p class="text-2xl font-bold text-white">
              <AccentText
                text={priceFormatter.format(vehicle.price)}
                accentClass={accent.tailwindText}
              />
            </p>
          </div>
          <div class="rounded-xl border border-slate-700/50 bg-slate-800/50 p-4 backdrop-blur-sm">
            <p class="mb-1 text-xs font-semibold tracking-wider text-slate-400 uppercase">
              Mileage
            </p>
            <p class="text-2xl font-bold text-white">
              {mileageFormatter.format(vehicle.mileage)} mi
            </p>
          </div>
          {
            originalMsrp ? (
              <div class="rounded-xl border border-slate-700/50 bg-slate-800/50 p-4 backdrop-blur-sm">
                <p class="mb-1 text-xs font-semibold tracking-wider text-slate-400 uppercase">
                  Original MSRP
                </p>
                <p class="text-2xl font-bold text-slate-300">
                  {priceFormatter.format(originalMsrp)}
                </p>
              </div>
            ) : (
              <div class="rounded-xl border border-slate-700/50 bg-slate-800/50 p-4 backdrop-blur-sm">
                <p class="mb-1 text-xs font-semibold tracking-wider text-slate-400 uppercase">
                  Listed In
                </p>
                <p class="text-2xl font-bold text-white">{vehicle.location.city}</p>
              </div>
            )
          }
        </div>
      </div>

      <div class="p-8 md:p-10">
        {
          sellersNote && pitchBlocks.length > 0 ? (
            <>
              <div class="prose prose-slate mb-10 max-w-none text-sm leading-relaxed text-slate-700 md:text-base">
                <div class="space-y-4 text-lg whitespace-pre-wrap text-slate-800">
                  {pitchIntro.split('\n\n').map((paragraph) => (
                    <p>{paragraph}</p>
                  ))}
                </div>
              </div>

              <div class="grid grid-cols-1 gap-x-12 gap-y-10 md:grid-cols-2">
                {
                  pitchBlocks.map((block, index) => (
                    <div>
                      <div class="mb-4 flex items-center gap-3">
                        <div
                          class={
                            index === 0
                              ? `rounded-lg border p-2 ${accent.tailwindSoftBorder} ${accent.tailwindSoftBg} ${accent.tailwindText}`
                              : 'rounded-lg border border-slate-200 bg-slate-100 p-2 text-slate-700'
                          }
                        >
                          <span class="text-xl">{block.icon ?? '•'}</span>
                        </div>
                        <h3 class="m-0 text-lg font-bold text-slate-900 md:text-xl">
                          {block.title}
                        </h3>
                      </div>
                      <div class="text-sm leading-relaxed text-slate-700 md:text-base">
                        <MarkdownText text={block.body} accentClass={accent.tailwindText} />
                      </div>
                      {
                        block.images && block.images.length > 0 && (
                          <div class="mt-6 grid grid-cols-3 gap-2">
                            {
                              block.images.map((imageUrl) => (
                                <div class="aspect-video overflow-hidden rounded-lg border border-slate-300 bg-slate-200">
                                  <img
                                    src={imageUrl}
                                    alt=""
                                    class="h-full w-full object-cover opacity-60 mix-blend-multiply"
                                  />
                                </div>
                              ))
                            }
                          </div>
                        )
                      }
                    </div>
                  ))
                }
              </div>

              {
                sellersNote?.ctaText && (
                  <div class="mt-12 rounded-xl border border-slate-200 bg-slate-50 p-6 text-center md:p-8">
                    <div class="mb-6 whitespace-pre-wrap text-slate-700">
                      {sellersNote.ctaText.split('\n\n').map((paragraph) => (
                        <p class="mb-4 text-base last:mb-0">{paragraph}</p>
                      ))}
                    </div>
                    <a
                      href="#contact"
                      class={`inline-flex items-center justify-center rounded-lg px-6 py-3 font-bold text-white transition-colors hover:brightness-90 ${accent.tailwindBg}`}
                    >
                      {ctaButtonLabel}
                    </a>
                  </div>
                )
              }
            </>
          ) : (
            <p class="max-w-none text-sm leading-relaxed text-slate-700 md:text-base">
              {vehicle.description}
            </p>
          )
        }
      </div>
    </div>
  </section>

  {
    vehicle.galleryPhotos && vehicle.galleryPhotos.length > 0 && (
      <Gallery client:load photos={vehicle.galleryPhotos} />
    )
  }

  <section id="maintenance" class="mb-16 pt-8">
    <div class="rounded-2xl border border-slate-200 bg-white p-8 shadow-sm md:p-10">
      {
        vehicle.mechanicalIntegrity ? (
          <>
            <div class="mb-8 max-w-3xl">
              <h2 class="mb-3 text-2xl font-bold text-slate-900">
                Mechanical Integrity & Upgrades
              </h2>
              <div class="text-sm leading-relaxed text-slate-500">
                <MarkdownText
                  text={
                    vehicle.mechanicalIntegrity.intro ??
                    'Documented mechanical upgrades and proactive maintenance provided by the seller.'
                  }
                  accentClass={accent.tailwindText}
                />
              </div>
            </div>

            <div class="mb-12 grid grid-cols-1 gap-6 md:grid-cols-3">
              {
                vehicle.mechanicalIntegrity.items.map((item) => (
                  <div class="rounded-xl border border-dashed border-slate-300 bg-slate-50 p-5">
                    <div class={`mb-4 h-1 w-8 ${accent.tailwindBg}`} />
                    <h3 class="mb-2 text-sm font-semibold text-slate-900">
                      <MarkdownText
                        text={item.title}
                        accentClass={accent.tailwindText}
                        inline
                      />
                    </h3>
                    <div class="text-xs leading-relaxed text-slate-500">
                      <MarkdownText text={item.text} accentClass={accent.tailwindText} />
                    </div>
                  </div>
                ))
              }
            </div>

            <div class="mb-8 border-t border-slate-100 pt-8">
              <h3 class="mb-3 text-xl font-bold text-slate-900">Service History</h3>
              <p class="mb-6 text-sm leading-relaxed text-slate-500">
                Documented service records provided by the seller.
              </p>
            </div>
          </>
        ) : (
          <div class="mb-8 max-w-3xl">
            <h2 class="mb-3 text-2xl font-bold text-slate-900">Maintenance History</h2>
            <p class="text-sm leading-relaxed text-slate-500">
              Documented service records provided by the seller.
            </p>
          </div>
        )
      }

      <ServiceTimeline client:visible records={vehicle.serviceRecords ?? []} accentColor={vehicle.accentColor} />
    </div>
  </section>

  {
    vehicle.marketValuation && (
      <MarketChart
        client:only="react"
        price={vehicle.price}
        mileage={vehicle.mileage}
        valuation={vehicle.marketValuation}
        images={marketImageUrls}
        accentColor={vehicle.accentColor}
      />
    )
  }

  <section id="features" class="mb-16 pt-8">
    <h2 class="mb-6 text-2xl font-bold text-slate-900">
      {vehicle.highlights?.length ? 'Vehicle Highlights & Utility' : 'Features & Equipment'}
    </h2>
    <div
      class={
        vehicle.highlights?.length
          ? 'grid grid-cols-1 gap-4 md:grid-cols-2 lg:grid-cols-4'
          : 'grid grid-cols-1 gap-4 md:grid-cols-2 lg:grid-cols-3'
      }
    >
      {
        vehicle.highlights?.length
          ? vehicle.highlights.map((highlight) => (
              <div class="rounded-xl border border-slate-200 bg-white p-5 shadow-sm transition-transform hover:-translate-y-1">
                <div class="mb-3 flex items-center gap-3">
                  <span class={`text-lg font-bold italic ${accent.tailwindText}`}>✔</span>
                  <h3 class="text-sm font-bold text-slate-900">
                    <MarkdownText
                      text={highlight.title}
                      accentClass={accent.tailwindText}
                      inline
                    />
                  </h3>
                </div>
                <div class="text-xs leading-relaxed text-slate-500">
                  <MarkdownText text={highlight.text} accentClass={accent.tailwindText} />
                </div>
              </div>
            ))
          : vehicle.features.map((feature) => (
              <div class="rounded-xl border border-slate-200 bg-white p-5 shadow-sm transition-transform hover:-translate-y-1">
                <div class="flex items-center gap-3">
                  <Check size={18} className={accent.tailwindText} />
                  <h3 class="text-sm font-bold text-slate-900">{feature}</h3>
                </div>
              </div>
            ))
      }
    </div>
  </section>

  <section id="specs" class="mb-16 pt-8">
    <h2 class="mb-6 text-2xl font-bold text-slate-900">Vehicle Specifications</h2>
    <div class="grid grid-cols-1 gap-4 sm:grid-cols-2 lg:grid-cols-3">
      {
        specItems.map((item) => {
          const Icon = item.icon;
          const value = vehicle.specs[item.key];
          return (
            <div class="rounded-xl border border-slate-200 bg-white p-5 shadow-sm">
              <div class="mb-3 flex items-center gap-3">
                <div class={`rounded-lg border p-2 ${accent.tailwindSoftBorder} ${accent.tailwindSoftBg} ${accent.tailwindText}`}>
                  <Icon size={20} />
                </div>
                <span class="text-[10px] font-bold text-slate-400 uppercase">{item.label}</span>
              </div>
              <p class="text-sm font-semibold text-slate-900">{value}</p>
            </div>
          );
        })
      }
    </div>
  </section>

  <ContactForm
    client:load
    vehicleId={vehicle.id}
    sellerId={vehicle.sellerId}
    isLoggedIn={buyerContext?.isLoggedIn ?? false}
    verificationTier={buyerContext?.verificationTier ?? 'anonymous'}
    userEmail={buyerContext?.userEmail ?? ''}
    userDisplayName={buyerContext?.userDisplayName ?? ''}
    userPhone={buyerContext?.userPhone ?? ''}
    loginHref={buyerContext?.loginHref ?? '/login'}
  />

  {
    showDocumentsSection ? (
      <section id="documents" class="mb-16 pt-8">
        <h2 class="mb-6 text-2xl font-bold text-slate-900">Vehicle Documents</h2>

        {
          vehicle.documentsBanner && (
            <section class="mb-8 rounded-xl border border-slate-200 bg-white p-6 shadow-sm">
              <div class="flex flex-col items-start justify-between gap-6 md:flex-row md:items-center">
                <div>
                  {
                    vehicle.documentsBanner.title && (
                      <h3 class="mb-1 text-sm font-bold text-slate-900">
                        {vehicle.documentsBanner.title}
                      </h3>
                    )
                  }
                  {
                    vehicle.documentsBanner.description && (
                      <p class="text-xs text-slate-500">
                        {vehicle.documentsBanner.description}
                      </p>
                    )
                  }
                </div>
                {
                  vehicle.documentsBanner.badges &&
                    vehicle.documentsBanner.badges.length > 0 && (
                      <div class="flex flex-wrap gap-3">
                        {
                          vehicle.documentsBanner.badges.map((badge) => (
                            <div class="rounded border border-slate-200 bg-slate-50 px-3 py-1.5 text-xs font-semibold text-slate-700">
                              ✓ {badge}
                            </div>
                          ))
                        }
                      </div>
                    )
                }
              </div>
            </section>
          )
        }

        {showWindowStickerSection && (
          <section id="build-sheet" class="mb-16 rounded-2xl border border-slate-200 bg-white p-8 shadow-sm md:p-10">
            <div class="mb-8 flex flex-col gap-4 border-b border-slate-100 pb-6 md:flex-row md:items-end md:justify-between">
              <div>
                <h3 class="mb-2 text-2xl font-bold text-slate-900">Original Window Sticker</h3>
                <p class="text-sm text-slate-500">Factory installed options and original MSRP.</p>
              </div>
              {
                (monroney || windowStickerBreakdown) && (
                  <div class="text-left md:text-right">
                    <span class={`mb-1 block text-[10px] font-bold uppercase ${accent.tailwindText}`}>
                      Total Price
                    </span>
                    <span class="text-3xl font-bold text-slate-900">
                      {priceFormatter.format(
                        monroney?.totalMsrp ?? windowStickerBreakdown!.totalMsrp
                      )}
                    </span>
                  </div>
                )
              }
            </div>

            {
              originalStickerUrl ? (
                <div class="mb-8 rounded-xl border border-slate-100 bg-white p-6 shadow-sm">
                  <SingleDocumentViewer
                    client:load
                    vehicleId={vehicle.id}
                    url={originalStickerUrl}
                    title="Original Window Sticker"
                    description="Factory installed options and original MSRP."
                    proxyApiRoute={`/api/vehicles/${vehicle.id}/original-sticker`}
                  />
                </div>
              ) : showGeneratedSticker && monroney ? (
                <div class="mb-8">
                  <WindowSticker
                    monroney={monroney}
                    vehicleTitle={pageTitle}
                    make={vehicle.make}
                    model={vehicle.model}
                    vin={vehicle.vin}
                    year={vehicle.year}
                    specs={vehicle.specs}
                    styleLine={monroneyStyleLine}
                  />
                </div>
              ) : null
            }

            {
              windowStickerBreakdown && !monroney && !originalStickerUrl && (
                <div class="grid grid-cols-1 gap-x-12 gap-y-2 text-sm md:grid-cols-2">
                  {windowStickerBreakdown.lineItems.map((item) => (
                    <div class="flex justify-between border-b border-slate-50 py-2">
                      <span
                        class={
                          item.emphasized
                            ? 'font-semibold text-slate-900'
                            : 'text-slate-700'
                        }
                      >
                        {item.label}
                      </span>
                      <span class="text-slate-600">
                        {priceFormatter.format(item.price)}
                      </span>
                    </div>
                  ))}
                </div>
              )
            }
          </section>
        )}

        {historyReportUrls.length > 0 && (
          <section id="carfax" class="mb-16 rounded-xl border border-slate-200 bg-white p-8 shadow-sm">
            <div class="mb-8">
              <h3 class="mb-2 text-2xl font-bold tracking-tight text-slate-900">
                Vehicle History Report
              </h3>
              <p class="text-sm text-slate-500">
                Detailed vehicle history and condition report.
              </p>
            </div>
            <HistoryReportViewer
              client:load
              vehicleId={vehicle.id}
              urls={historyReportUrls}
            />
          </section>
        )}

        {kbbReportUrl && (
          <section id="kbb" class="mb-16 rounded-xl border border-slate-200 bg-white p-8 shadow-sm">
            <div class="mb-8">
              <h3 class="mb-2 text-2xl font-bold tracking-tight text-slate-900">
                Kelley Blue Book Valuation
              </h3>
              <p class="text-sm text-slate-500">Private Party Market Value Estimate</p>
            </div>
            <SingleDocumentViewer
              client:load
              vehicleId={vehicle.id}
              url={kbbReportUrl}
              title="Kelley Blue Book Valuation"
              description="Private Party Market Value Estimate"
              proxyApiRoute={`/api/vehicles/${vehicle.id}/kbb-report`}
            />
          </section>
        )}

        {smogCertificateUrls.length > 0 && (
          <section id="smog" class="mb-16 rounded-xl border border-slate-200 bg-white p-8 shadow-sm">
            <div class="mb-8">
              <h3 class="mb-2 text-2xl font-bold tracking-tight text-slate-900">
                Emissions & Compliance
              </h3>
              <p class="text-sm text-slate-500">Official passing inspection report</p>
            </div>
            <HistoryReportViewer
              client:load
              vehicleId={vehicle.id}
              urls={smogCertificateUrls}
              title="Smog & Emissions Certificate"
              proxySegment="smog-certificate"
            />
          </section>
        )}

        {otherDocuments.map((doc) => {
          const Icon = doc.icon;
          return (
            <section id={doc.id} class="mb-16 rounded-xl border border-slate-200 bg-white p-8 shadow-sm">
              <div class="mb-8">
                <h3 class="mb-2 text-2xl font-bold tracking-tight text-slate-900">{doc.title}</h3>
                <p class="text-sm text-slate-500">{doc.description}</p>
              </div>
              <div class="rounded-xl border border-slate-100 bg-white p-6 shadow-sm">
                {isPdfUrl(doc.url) && canEmbedPdf(doc.url) ? (
                  <iframe
                    src={doc.url}
                    title={doc.title}
                    class="h-[600px] w-full border-0 bg-white"
                  />
                ) : isPdfUrl(doc.url) ? null : (
                  <img
                    src={doc.url}
                    alt={doc.title}
                    class="h-auto w-full bg-white object-contain"
                  />
                )}
                <a
                  href={doc.url}
                  target="_blank"
                  rel="noopener noreferrer"
                  class="mt-4 flex items-center gap-3 rounded-xl border border-slate-200 bg-slate-50 p-4 transition-colors hover:bg-slate-100"
                >
                  <div class="rounded-full bg-white p-3 shadow-sm">
                    <Icon size={24} className="text-slate-400" />
                  </div>
                  <span class="text-sm font-semibold text-slate-900">
                    View / Download {doc.title}
                  </span>
                  <Download size={16} className="ml-auto text-slate-400" />
                </a>
              </div>
            </section>
          );
        })}
      </section>
    ) : (
      import.meta.env.DEV && (
        <section id="documents" class="mb-16 pt-8">
          <div class="rounded-xl border border-dashed border-slate-300 bg-white p-8 text-center">
            <p class="text-sm font-medium text-slate-700">No documents on this listing yet</p>
            <p class="mt-2 text-sm text-slate-500">
              Re-seed sample data to populate documents:{' '}
              <a href="/api/dev/seed" class={`font-semibold underline ${accent.tailwindText}`}>
                /api/dev/seed
              </a>
            </p>
          </div>
        </section>
      )
    )
  }

  <ChatWidget client:load vehicleId={vehicle.id} sellerName={vehicle.sellerName} />
</main>

<footer class="border-t border-slate-800 bg-slate-900 py-8 text-center">
  <p class="text-xs font-medium tracking-wider text-slate-500 uppercase">
    {pageTitle} • Buyer's Guide
  </p>
</footer>
