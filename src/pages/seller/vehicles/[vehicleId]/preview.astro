---
import { db } from '../../../../lib/firebase-admin';
import {
  assertVehicleOwner,
  ForbiddenError,
  requireSellerOrRedirect,
} from '../../../../lib/auth';
import { mapInquiryDoc } from '../../../../lib/inquiries';
import { resolveVehicleDisplayMonroney } from '../../../../lib/resolve-display-monroney';
import { VehicleResponseSchema } from '../../../../schemas';
import SellerPreviewFrame from '../../../../islands/seller/SellerPreviewFrame';
import VehicleListingContent from '../../../../components/VehicleListingContent.astro';
import '../../../../styles/global.css';

const { vehicleId } = Astro.params;

if (!vehicleId) {
  return new Response('Vehicle not found', { status: 404, statusText: 'Not Found' });
}

const seller = await requireSellerOrRedirect(Astro.request, Astro.cookies);
if (seller instanceof Response) return seller;

const doc = await db().collection('vehicles').doc(vehicleId).get();

if (!doc.exists) {
  return new Response('Vehicle not found', { status: 404, statusText: 'Not Found' });
}

const raw = { id: doc.id, ...doc.data() };
const parsed = VehicleResponseSchema.safeParse(raw);

if (!parsed.success) {
  return new Response('Vehicle not found', { status: 404, statusText: 'Not Found' });
}

try {
  assertVehicleOwner(seller.uid, parsed.data.sellerId);
} catch (error) {
  if (error instanceof ForbiddenError) {
    return new Response('Forbidden', { status: 403, statusText: 'Forbidden' });
  }
  throw error;
}

const vehicle = parsed.data;
const displayMonroney = await resolveVehicleDisplayMonroney(vehicle);
const listingVehicle = displayMonroney ? { ...vehicle, monroney: displayMonroney } : vehicle;
const vehicleTitle = `${listingVehicle.year} ${listingVehicle.make} ${listingVehicle.model}`;

const inquirySnapshot = await db()
  .collection('inquiries')
  .where('sellerId', '==', seller.uid)
  .where('vehicleId', '==', vehicleId)
  .orderBy('timestamp', 'desc')
  .get();

const inquiryCount = inquirySnapshot.docs.reduce((count, inquiryDoc) => {
  const parsedInquiry = mapInquiryDoc(inquiryDoc.id, inquiryDoc.data() as Record<string, unknown>);
  return parsedInquiry.success ? count + 1 : count;
}, 0);
---

<html lang="en">
  <head>
    <meta charset="utf-8" />
    <link rel="icon" type="image/svg+xml" href="/favicon.svg" />
    <link rel="icon" href="/favicon.ico" />
    <meta name="viewport" content="width=device-width" />
    <meta name="generator" content={Astro.generator} />
    <title>{vehicleTitle} · Preview · Seller Dashboard</title>
  </head>
  <body class="flex min-h-screen flex-col bg-[#f8f9fa] font-sans text-slate-900">
    <SellerPreviewFrame
      client:load
      vehicleId={vehicleId}
      vehicleTitle={vehicleTitle}
      sellerUid={seller.uid}
      inquiryCount={inquiryCount}
    />
    <div class="flex-1 overflow-y-auto">
      <VehicleListingContent vehicle={listingVehicle} analyticsEnabled={false} />
    </div>
  </body>
</html>
